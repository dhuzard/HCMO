    rdfs:comment "Deprecated HCMO 0.0.1 term retained for backward compatibility." ;
    owl:deprecated true .

hcm-obs:GasConcentrationObservation a owl:Class ;
    rdfs:label "Gas Concentration Observation" ;
    rdfs:comment "An environment observation measuring or reporting the concentration of a gas." ;
    rdfs:subClassOf hcm-obs:EnvironmentObservation .

hcm-obs:HousingAssignment a owl:Class ;
    rdfs:label "Housing Assignment" ;
    dcterms:isReplacedBy hcm-bio:HousingAssignment ;
    dcterms:source <https://w3id.org/hcmo/ontology/hcm/0.0.1> ;
    rdfs:comment "Deprecated HCMO 0.0.1 term retained for backward compatibility." ;
    owl:deprecated true .

hcm-obs:assignedToEnclosure a owl:ObjectProperty ;
    rdfs:label "assigned to enclosure" ;
    dcterms:isReplacedBy hcm-bio:assignedToEnclosure ;
    dcterms:source <https://w3id.org/hcmo/ontology/hcm/0.0.1> ;
    rdfs:comment "Deprecated HCMO 0.0.1 term retained for backward compatibility." ;
    owl:deprecated true .

hcm-obs:hasBehaviorType a owl:DatatypeProperty ;
    rdfs:label "has behavior type" ;
    rdfs:comment "Records the behavior type or behavior category associated with a behavior observation or result." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-obs:BehaviorObservation hcm-obs:BehaviorResult ) ] ;
    rdfs:range xsd:string .

hcm-obs:hasCondition a owl:ObjectProperty ;
    rdfs:label "has condition" ;
    rdfs:comment "Relates an observation to the condition under which it was made or interpreted; the condition model is intentionally left open." ;
    rdfs:domain sosa:Observation ;
    rdfs:range owl:Thing .

hcm-obs:hasConfidenceScore a owl:DatatypeProperty ;
    rdfs:label "has confidence score" ;
    rdfs:comment "Records a numeric confidence score associated with an observation result." ;
    rdfs:domain hcm-obs:ObservationResult ;
    rdfs:range xsd:decimal .

hcm-obs:hasHealthStatusTerm a owl:DatatypeProperty ;
    rdfs:label "has health status term" ;
    rdfs:comment "Records a textual or coded health-status term associated with a health-status observation." ;
    rdfs:domain hcm-obs:HealthStatusObservation ;
    rdfs:range xsd:string .

hcm-obs:hasInterval a owl:DatatypeProperty ;
    rdfs:label "has interval" ;
    rdfs:comment "Records a duration associated with an observation; use sosa:phenomenonTime for a temporal entity. The xsd:duration datatype is enforced by SHACL because it is outside the OWL 2 datatype map." ;
    rdfs:domain sosa:Observation ;
    rdfs:range rdfs:Literal .

hcm-obs:occursIn a owl:ObjectProperty ;
    rdfs:label "occurs in" ;
    rdfs:comment "Relates an observation to the enclosure in which it occurs." ;
    rdfs:domain sosa:Observation ;
    rdfs:range hcm:Enclosure .

hcm-tech:hasActuator a owl:ObjectProperty ;
    rdfs:label "has actuator" ;
    rdfs:comment "Relates a monitored enclosure to an actuator associated with it." ;
    rdfs:domain hcm:MonitoredEnclosure ;
    rdfs:range hcm-tech:Actuator .

hcm-tech:hasFirmware a owl:DatatypeProperty ;
    rdfs:label "has firmware" ;
    rdfs:comment "Records the firmware identifier or version installed on a hardware or sensor component." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-tech:Hardware hcm-tech:Sensor ) ] ;
    rdfs:range xsd:string .

hcm-tech:hasModelNumber a owl:DatatypeProperty ;
    rdfs:label "has model number" ;
    rdfs:comment "Records the manufacturer model number for a hardware, sensor, or actuator component." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-tech:Hardware hcm-tech:Sensor hcm-tech:Actuator ) ] ;
    rdfs:range xsd:string .

hcm-tech:hasProtocol a owl:DatatypeProperty ;
    rdfs:label "has protocol" ;
    rdfs:comment "Records the communication, acquisition, or processing protocol used by a technical component." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-tech:Hardware hcm-tech:Sensor hcm-tech:Software ) ] ;
    rdfs:range xsd:string .

hcm-tech:hasSensorIdentifier a owl:DatatypeProperty ;
    rdfs:label "has sensor identifier" ;
    rdfs:comment "Records an identifier assigned to a sensor." ;
    rdfs:domain hcm-tech:Sensor ;
    rdfs:range xsd:string .

hcm-tech:hasSensorTechnology a owl:DatatypeProperty ;
    rdfs:label "has sensor technology" ;
    rdfs:comment "Records the sensing technology or modality used by a sensor." ;
    rdfs:domain hcm-tech:Sensor ;
    rdfs:range xsd:string .

hcm-tech:hasSensorType a owl:DatatypeProperty ;
    rdfs:label "has sensor type" ;
    rdfs:comment "Records the functional type or category of a sensor." ;
    rdfs:domain hcm-tech:Sensor ;
    rdfs:range xsd:string .

hcm-tech:isCalibrated a owl:DatatypeProperty ;
    rdfs:label "is calibrated" ;
    rdfs:comment "Indicates whether a sensor or device has been calibrated." ;
    rdfs:domain hcm-tech:Sensor ;
    rdfs:range xsd:boolean .

hcm-tech:runsOn a owl:ObjectProperty ;
    rdfs:label "runs on" ;
    rdfs:comment "Relates software to the hardware or platform on which it executes." ;
    rdfs:domain hcm-tech:Software ;
    rdfs:range hcm-tech:Hardware .

hcm-tech:supportsEnclosure a owl:ObjectProperty ;
    rdfs:label "supports enclosure" ;
    rdfs:comment "Relates a technical component to the monitored enclosure that it supports." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-tech:Hardware hcm-tech:Software ) ] ;
    rdfs:range hcm:MonitoredEnclosure .

mod:createdWith a owl:AnnotationProperty .

mod:status a owl:AnnotationProperty .

<https://orcid.org/0000-0002-2923-9790> a schema:Person ;
    schema:name "Pierre Larmande" .

<https://orcid.org/0000-0002-6085-6818> a schema:Person ;
    schema:name "Serge Sonfack Sounchio" .

<https://orcid.org/0000-0002-9116-6692> a schema:Person ;
    schema:name "Konstantin Todorov" .

<https://orcid.org/0000-0003-2204-2466> a schema:Person ;
    schema:name "Gaoussou Sanou" .

<https://orcid.org/0000-0003-4820-7951> a schema:Person ;
    schema:name "Damien Huzard" .

<https://orcid.org/0009-0008-0575-8490> a schema:Person ;
    schema:name "Antoine Toffano" .

<https://orcid.org/0009-0008-2489-8106> a schema:Person ;
    schema:name "Cyril Gilbert" .

hcm:hasDimensions a owl:ObjectProperty ;
    rdfs:label "has dimensions" ;
    rdfs:comment "Links an enclosure to its dimensions record." ;
    rdfs:domain hcm:Enclosure ;
    rdfs:range hcm:EnclosureDimensions .

hcm:hasMonitoredAnimals a owl:ObjectProperty ;
    rdfs:label "has monitored animals" ;
    rdfs:comment "Relates a monitored enclosure to the biological subjects housed or tracked within it." ;
    rdfs:domain hcm:MonitoredEnclosure ;
    rdfs:range hcm-bio:Subject .

hcm:hasUnit a owl:DatatypeProperty ;
    rdfs:label "has unit" ;
    rdfs:comment "Records the measurement unit associated with a quantitative observation result or measurement specification." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-obs:QuantityValue hcm-env:MeasurementSpecification ) ] ;
    rdfs:range xsd:string .

hcm-bio:StudyFactors a owl:Class ;
    rdfs:label "Study Factor" ;
    rdfs:comment "An independent variable that an investigation is designed to vary systematically in order to determine its effect on subjects or observations." ;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/IAO_0000030> .

hcm-bio:assignedToEnclosure a owl:ObjectProperty ;
    rdfs:label "assigned to enclosure" ;
    rdfs:comment "Relates a housing assignment to the enclosure or monitored enclosure involved in that assignment." ;
    rdfs:domain hcm-bio:HousingAssignment ;
    rdfs:range hcm:Enclosure .

hcm-bio:hasBehaviorObservation a owl:ObjectProperty ;
    rdfs:label "has behavior observation" ;
    rdfs:comment "Relates a subject to a behavior observation about that subject." ;
    rdfs:domain hcm-bio:Subject ;
    rdfs:range hcm-obs:BehaviorObservation .

hcm-env:ThriveProfile a owl:Class ;
    rdfs:label "Thrive Profile" ;
    rdfs:comment "A welfare or husbandry profile describing environmental conditions intended to support animal thriving." ;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/IAO_0000030> .

hcm-env:hasGasConcentrationProfile a owl:ObjectProperty ;
    rdfs:label "has gas concentration profile" ;
    rdfs:comment "Relates an environment profile to a gas concentration profile." ;
    rdfs:domain hcm-env:EnvironmentProfile ;
    rdfs:range hcm-env:GasConcentrationProfile .

hcm-env:hasLightCycle a owl:ObjectProperty ;
    rdfs:label "has light cycle" ;
    rdfs:comment "Relates an environment profile to a light cycle." ;
    rdfs:domain hcm-env:EnvironmentProfile ;
    rdfs:range hcm-env:LightCycle .

hcm-env:hasMeasurementSpec a owl:ObjectProperty ;
    rdfs:label "has measurement spec" ;
    rdfs:comment "Relates an environment profile to a measurement specification." ;
    rdfs:domain hcm-env:EnvironmentProfile ;
    rdfs:range hcm-env:MeasurementSpecification .

hcm-env:hasThriveProfile a owl:ObjectProperty ;
    rdfs:label "has thrive profile" ;
    rdfs:comment "Relates a monitored enclosure to the thrive profile that specifies suitable husbandry or environmental conditions." ;
    rdfs:domain hcm:MonitoredEnclosure ;
    rdfs:range hcm-env:ThriveProfile .

hcm-obs:LocationResultTable a owl:Class ;
    rdfs:label "Location Result Table" ;
    rdfs:comment "A tabular observation result containing location values or generated time-series segments." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom semts:TimeSeriesSegment ;
            owl:onProperty semts:generated ],
        hcm-obs:ObservationResult .

hcm-obs:WeightObservation a owl:Class ;
    rdfs:label "Weight Observation" ;
    rdfs:comment "A SOSA-style observation reporting the body weight of a biological subject." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sosa:hasResult ;
            owl:someValuesFrom hcm-obs:QuantityValue ],
        [ a owl:Restriction ;
            owl:onProperty sosa:hasFeatureOfInterest ;
            owl:someValuesFrom hcm-bio:Subject ],
        sosa:Observation .

hcm-obs:hasCategory a owl:DatatypeProperty ;
    rdfs:label "has category" ;
    rdfs:comment "Records the category assigned to a categorical observation result." ;
    rdfs:domain hcm-obs:CategoricalResult ;
    rdfs:range xsd:string .

hcm-obs:hasNumericValue a owl:DatatypeProperty ;
    rdfs:label "has numeric value" ;
    rdfs:comment "Records the numeric value of a quantity result or measurement." ;
    rdfs:domain hcm-obs:QuantityValue ;
    rdfs:range xsd:decimal .

hcm-tech:captures a owl:ObjectProperty ;
    rdfs:label "captures" ;
    rdfs:comment "Relates a sensor to the property it observes or captures." ;
    rdfs:domain hcm-tech:Sensor ;
    rdfs:range sosa:Property ;
    rdfs:subPropertyOf sosa:observes .

hcm-tech:communicatesWith a owl:ObjectProperty ;
    rdfs:label "communicates with" ;
    rdfs:comment "Relates a technical component to another hardware or software component with which it exchanges data or commands." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-tech:Hardware hcm-tech:Sensor hcm-tech:Actuator hcm-tech:Software ) ] ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( hcm-tech:Hardware hcm-tech:Sensor hcm-tech:Actuator hcm-tech:Software ) ] .

hcm-tech:hasFileFormat a owl:DatatypeProperty ;
    rdfs:label "has file format" ;
    rdfs:comment "Records the file format of a software or time-series artifact." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-tech:Software hcm-tech:TimeSeries ) ] ;
    rdfs:range xsd:string .

hcm-tech:hasSamplingRate a owl:DatatypeProperty ;
    rdfs:label "has sampling rate" ;
    rdfs:comment "Records the rate at which a sensor or data stream is sampled, including its unit." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-tech:Sensor hcm-tech:TimeSeries ) ] ;
    rdfs:range xsd:string .

hcm-tech:hasStoragePath a owl:DatatypeProperty ;
    rdfs:label "has storage path" ;
    rdfs:comment "Records a path or locator for stored data, software, or time-series resources." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-tech:Software hcm-tech:TimeSeries ) ] ;
    rdfs:range xsd:string .

hcm-tech:hasVersion a owl:DatatypeProperty ;
    rdfs:label "has version" ;
    rdfs:comment "Records a version string for software, firmware, hardware, or data artifacts." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-tech:Hardware hcm-tech:Software hcm-tech:TimeSeries ) ] ;
    rdfs:range xsd:string .

hcm:Enrichment a owl:Class ;
    rdfs:label "Enrichment" ;
    rdfs:comment "A material or structure provided within an enclosure to support animal welfare or experimental conditions." ;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000040> .

hcm:hasDimUnit a owl:DatatypeProperty ;
    rdfs:label "has dim unit" ;
    rdfs:comment "Records the unit used for enclosure dimension values." ;
    rdfs:domain hcm:EnclosureDimensions ;
    rdfs:range xsd:string .

hcm:hasHeight a owl:DatatypeProperty ;
    rdfs:label "has height" ;
    rdfs:comment "Records the height value of an enclosure dimensions record." ;
    rdfs:domain hcm:EnclosureDimensions ;
    rdfs:range xsd:decimal .

hcm:hasLength a owl:DatatypeProperty ;
    rdfs:label "has length" ;
    rdfs:comment "Records the length value of an enclosure dimensions record." ;
    rdfs:domain hcm:EnclosureDimensions ;
    rdfs:range xsd:decimal .

hcm:hasWidth a owl:DatatypeProperty ;
    rdfs:label "has width" ;
    rdfs:comment "Records the width value of an enclosure dimensions record." ;
    rdfs:domain hcm:EnclosureDimensions ;
    rdfs:range xsd:decimal .

hcm-env:hasEnvironment a owl:ObjectProperty ;
    rdfs:label "has environment" ;
    rdfs:comment "Relates an enclosure to a structured environment profile." ;
    rdfs:domain hcm:Enclosure ;
    rdfs:range hcm-env:EnvironmentProfile .

hcm-obs:BehaviorResult a owl:Class ;
    rdfs:label "Behavior Result" ;
    rdfs:comment "An observation result representing a detected, classified, or recorded behavior." ;
    rdfs:subClassOf hcm-obs:ObservationResult .

hcm-obs:CategoricalResult a owl:Class ;
    rdfs:label "Categorical Result" ;
    rdfs:comment "An observation result represented by a category rather than a numeric value." ;
    rdfs:subClassOf hcm-obs:ObservationResult .

hcm-obs:HealthStatusObservation a owl:Class ;
    rdfs:label "Health Status Observation" ;
    rdfs:comment "A SOSA-style observation about the health status of a biological subject." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sosa:hasFeatureOfInterest ;
            owl:someValuesFrom hcm-bio:Subject ],
        sosa:Observation .

hcm-tech:monitoredBy a owl:ObjectProperty ;
    rdfs:label "monitored by" ;
    rdfs:comment "Relates a monitored enclosure to a sensor installed in or monitoring it." ;
    rdfs:domain hcm:MonitoredEnclosure ;
    rdfs:range hcm-tech:Sensor ;
    owl:inverseOf hcm-tech:installedIn .

hcm-bio:HousingAssignment a owl:Class ;
    rdfs:label "Housing Assignment" ;
    rdfs:comment "A record assigning a subject or group to an enclosure in a study or housing context." ;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/IAO_0000030> .

hcm-obs:BehaviorObservation a owl:Class ;
    rdfs:label "Behavior Observation" ;
    rdfs:comment "A SOSA-style observation about the behavior of a subject in a home-cage monitoring context." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sosa:hasFeatureOfInterest ;
            owl:someValuesFrom hcm-bio:Subject ],
        [ a owl:Restriction ;
            owl:onProperty sosa:hasResult ;
            owl:someValuesFrom hcm-obs:BehaviorResult ],
        sosa:Observation .

hcm-tech:installedIn a owl:ObjectProperty ;
    rdfs:label "installed in" ;
    rdfs:comment "Relates a sensor to the monitored enclosure in which it is installed." ;
    rdfs:domain hcm-tech:Sensor ;
    rdfs:range hcm:MonitoredEnclosure .

hcm-env:GasConcentrationProfile a owl:Class ;
    rdfs:label "Gas Concentration Profile" ;
    rdfs:comment "A profile describing concentrations of gases relevant to the monitored enclosure environment." ;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/IAO_0000030> .

hcm-obs:QuantityValue a owl:Class ;
    rdfs:label "Quantity Value" ;
    rdfs:comment "An observation result that represents a quantitative value, typically with a numeric value and unit." ;
    rdfs:subClassOf hcm-obs:ObservationResult .

hcm-bio:ExperimentalGroup a owl:Class ;
    rdfs:label "Experimental Group" ;
    rdfs:comment "A group of biological subjects sharing an experimental condition, treatment, or study role." ;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000027> .

hcm-tech:Actuator a owl:Class ;
    rdfs:label "Actuator" ;
    rdfs:comment "A device that elicits or perturbs behavior, physiology, or the monitored environment." ;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000040>,
        sosa:Actuator .

hcm-tech:TimeSeries a owl:Class ;
    rdfs:label "Time Series" ;
    rdfs:comment "An ordered sequence of time-indexed measurements or outputs produced in a monitoring workflow." ;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/IAO_0000030> .

hcm-obs:ObservationResult a owl:Class ;
    rdfs:label "Observation Result" ;
    rdfs:comment "An information artifact produced as the result of a home-cage monitoring observation." ;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/IAO_0000030>,
        sosa:Result .

hcm-env:EnvironmentalProperty a owl:Class ;
    rdfs:label "Environmental Property" ;
    rdfs:comment "An environmental parameter that may be measured, specified, or controlled in a home-cage monitoring context." ;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000019>,
        sosa:Property .

hcm-env:LightCycle a owl:Class ;
    rdfs:label "Light Cycle" ;
    rdfs:comment "A description of the timing and transitions of light and dark phases in an enclosure environment." ;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/IAO_0000030> .

hcm-obs:EnvironmentObservation a owl:Class ;
    rdfs:label "Environment Observation" ;
    rdfs:comment "A SOSA-style observation about an environmental property of a monitored enclosure." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sosa:hasFeatureOfInterest ;
            owl:someValuesFrom hcm:MonitoredEnclosure ],
        [ a owl:Restriction ;
            owl:allValuesFrom semts:DataDimension ;
            owl:onProperty semts:hasDimension ],
        sosa:Observation .

hcm:EnclosureDimensions a owl:Class ;
    rdfs:label "Enclosure Dimensions" ;
    rdfs:comment "A dimensions record describing the physical size of an enclosure." ;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/IAO_0000030> .

hcm:MonitoredEnclosure a owl:Class ;
    rdfs:label "Monitored Enclosure" ;
    rdfs:comment "A physical enclosure equipped for the longitudinal monitoring of housed biological subjects." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom hcm-bio:Subject ;
            owl:onProperty hcm:hasMonitoredAnimals ],
        [ a owl:Restriction ;
            owl:allValuesFrom hcm-tech:Sensor ;
            owl:onProperty hcm-tech:monitoredBy ],
        [ a owl:Restriction ;
            owl:allValuesFrom hcm-env:EnvironmentProfile ;
            owl:onProperty hcm-env:hasEnvironment ],
        [ a owl:Restriction ;
            owl:allValuesFrom hcm:EnclosureDimensions ;
            owl:onProperty hcm:hasDimensions ],
        hcm:Enclosure .

hcm-tech:Hardware a owl:Class ;
    rdfs:label "Hardware" ;
    rdfs:comment "Physical computing hardware component of a home-cage monitoring system." ;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000040> .

hcm-tech:Software a owl:Class ;
    rdfs:label "Software" ;
    rdfs:comment "Software component used to acquire, process, store, or analyse home-cage monitoring data." ;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/IAO_0000030> .

hcm-env:MeasurementSpecification a owl:Class ;
    rdfs:label "Measurement Specification" ;
    rdfs:comment "A specification describing how an environmental property is measured, represented, or constrained." ;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/IAO_0000030> .

hcm-env:EnvironmentProfile a owl:Class ;
    rdfs:label "Environment Profile" ;
    rdfs:comment "A structured profile describing environmental conditions or requirements for a monitored enclosure." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom hcm-env:MeasurementSpecification ;
            owl:onProperty hcm-env:hasMeasurementSpec ],
        [ a owl:Restriction ;
            owl:allValuesFrom hcm-env:LightCycle ;
            owl:onProperty hcm-env:hasLightCycle ],
        [ a owl:Restriction ;
            owl:allValuesFrom hcm-env:GasConcentrationProfile ;
            owl:onProperty hcm-env:hasGasConcentrationProfile ],
        <http://purl.obolibrary.org/obo/IAO_0000030> .

hcm-tech:Sensor a owl:Class ;
    rdfs:label "Sensor" ;
    rdfs:comment "A device that captures signals related to behavior, physiology, or enclosure environment." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hcm-tech:installedIn ;
            owl:someValuesFrom hcm:MonitoredEnclosure ],
        <http://purl.obolibrary.org/obo/BFO_0000040>,
        sosa:Sensor .

hcm:Enclosure a owl:Class ;
    rdfs:label "Enclosure" ;
    rdfs:comment "A physical housing enclosure used as part of a home-cage monitoring system." ;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000040> .

hcm-bio:Subject a owl:Class ;
    rdfs:label "Subject" ;
    rdfs:comment "A biological individual, such as a laboratory animal, observed in a home-cage monitoring context." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom hcm-obs:BehaviorObservation ;
            owl:onProperty hcm-bio:hasBehaviorObservation ],
        <http://purl.obolibrary.org/obo/BFO_0000040> .

