    rdfs:comment "Deprecated HCMO 0.0.1 term retained for backward compatibility." ;
    owl:deprecated true .

hcm-env:hasLength a owl:DatatypeProperty ;
    rdfs:label "has length" ;
    dcterms:isReplacedBy hcm:hasLength ;
    dcterms:source <https://w3id.org/hcmo/ontology/hcm/0.0.1> ;
    rdfs:comment "Deprecated HCMO 0.0.1 term retained for backward compatibility." ;
    owl:deprecated true .

hcm-env:hasLightPhaseDuration a owl:DatatypeProperty ;
    rdfs:label "has light phase duration" ;
    rdfs:comment "Records the duration of the light phase in a light cycle; xsd:duration is enforced by SHACL because that datatype is outside the OWL 2 datatype map." ;
    rdfs:domain hcm-env:LightCycle ;
    rdfs:range rdfs:Literal .

hcm-env:hasUnit a owl:DatatypeProperty ;
    rdfs:label "has unit" ;
    dcterms:isReplacedBy hcm:hasUnit ;
    dcterms:source <https://w3id.org/hcmo/ontology/hcm/0.0.1> ;
    rdfs:comment "Deprecated duplicate; use the consolidated hcm:hasUnit property for quantitative results and measurement specifications." ;
    owl:deprecated true .

hcm-env:hasValue a owl:DatatypeProperty ;
    rdfs:label "has value" ;
    rdfs:comment "Records a literal value for an environmental measurement or specification." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-env:MeasurementSpecification hcm-env:GasConcentrationProfile ) ] ;
    rdfs:range rdfs:Literal .

hcm-env:hasWidth a owl:DatatypeProperty ;
