    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-env:EnvironmentProfile hcm-env:MeasurementSpecification hcm-obs:EnvironmentObservation ) ] ;
    rdfs:range hcm-env:EnvironmentalProperty .

hcm-env:CarbonDioxideConcentration a owl:ObjectProperty ;
