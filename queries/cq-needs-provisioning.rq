PREFIX hcm: <https://w3id.org/hcmo/ontology/hcm#>
PREFIX hcm-bio: <https://w3id.org/hcmo/ontology/hcm/bio#>

SELECT ?subject ?enclosure
WHERE {
  ?subject a hcm-bio:Subject ;
           hcm-bio:hasHousingAssignment ?assignment .
  ?assignment hcm-bio:assignedToEnclosure ?enclosure .
  FILTER (
    !EXISTS { ?enclosure hcm:hasFoodRequirement ?food } ||
    !EXISTS { ?enclosure hcm:hasWaterRequirement ?water } ||
    !EXISTS { ?enclosure hcm:hasSafetyRequirement ?safety } ||
    !EXISTS { ?enclosure hcm:hasEnrichmentRequirement ?enrichment }
  )
}
ORDER BY ?subject
