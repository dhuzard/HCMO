@prefix ex: <https://example.org/hcmo/invalid/> .
@prefix hcm: <https://w3id.org/hcmo/ontology/hcm#> .
@prefix hcm-bio: <https://w3id.org/hcmo/ontology/hcm/bio#> .
@prefix hcm-obs: <https://w3id.org/hcmo/ontology/hcm/obs#> .
@prefix hcm-tech: <https://w3id.org/hcmo/ontology/hcm/tech#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .

# Missing identifier, sensor, and monitored subject.
ex:enclosure-with-gaps a hcm:MonitoredEnclosure ;
  rdfs:label "Incomplete enclosure" ;
  hcm:hasDimensions ex:bad-dimensions .

# Invalid negative height.
ex:bad-dimensions a hcm:EnclosureDimensions ;
  hcm:hasWidth 30.0 ;
  hcm:hasLength 45.0 ;
  hcm:hasHeight -1.0 ;
  hcm:hasDimUnit "cm" .

# Missing species and housing assignment.
ex:subject-with-gaps a hcm-bio:Subject ;
  rdfs:label "Incomplete subject" .

# Missing enclosure target.
ex:assignment-with-gaps a hcm-bio:HousingAssignment .

# Missing sensor identifier and installation link.
ex:sensor-with-gaps a hcm-tech:Sensor ;
  rdfs:label "Incomplete sensor" .

# Missing feature of interest, sensor, result, and enclosure context.
ex:observation-with-gaps a hcm-obs:BehaviorObservation .

# Missing unit.
ex:quantity-with-gaps a hcm-obs:QuantityValue ;
  hcm-obs:hasNumericValue 12.0 .

# Missing storage path.
ex:series-with-gaps a hcm-tech:TimeSeries ;
  hcm-tech:hasFileFormat "text/csv" .
