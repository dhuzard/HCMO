@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ex: <https://w3id.org/hcmo/id/example-submission/> .
@prefix hcm: <https://w3id.org/hcmo/ontology/hcm#> .
@prefix hcm-bio: <https://w3id.org/hcmo/ontology/hcm/bio#> .
@prefix hcm-env: <https://w3id.org/hcmo/ontology/hcm/env#> .
@prefix hcm-tech: <https://w3id.org/hcmo/ontology/hcm/tech#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .

ex:enclosure-example-hcm a hcm:MonitoredEnclosure ;
  rdfs:label "Example HCM enclosure submission" ;
  rdfs:comment "Example generated from the HCMO contribution-form pattern." ;
  dcterms:contributor ex:contributor-jane-doe ;
  dcterms:relation ex:data-product-example-hcm ;
  dcterms:source "https://example.org/hcm-system" ;
  hcm:hasEnclosureIdentifier "example-cage-01" ;
  hcm:hasManufacturer "Example Vendor" ;
  hcm:hasDimensions ex:dimensions-example-hcm ;
  hcm:hasMonitoredAnimals ex:subject-example-hcm ;
  hcm-env:hasEnvironment ex:environment-example-hcm ;
  hcm-tech:monitoredBy ex:sensor-ir-camera .

ex:dimensions-example-hcm a hcm:EnclosureDimensions ;
  hcm:hasHeight 20.0 ;
  hcm:hasLength 45.0 ;
  hcm:hasWidth 30.0 ;
  hcm:hasDimUnit "cm" .

ex:environment-example-hcm a hcm-env:EnvironmentProfile ;
  hcm-env:hasMeasurementSpec ex:measurement-spec-activity .

ex:measurement-spec-activity a hcm-env:MeasurementSpecification ;
  rdfs:label "Activity index" .

ex:sensor-ir-camera a hcm-tech:Sensor ;
  rdfs:label "Infrared camera" ;
  hcm-tech:hasSensorIdentifier "camera-01" ;
  hcm-tech:hasSensorTechnology "infrared video" ;
  hcm-tech:hasSamplingRate "4 Hz" ;
  hcm-tech:installedIn ex:enclosure-example-hcm .

ex:subject-example-hcm a hcm-bio:Subject ;
  rdfs:label "Example mouse subject" ;
  hcm-bio:hasBiologicalSex "female" ;
  hcm-bio:hasSpecies "Mus musculus" ;
  hcm-bio:hasStrain "C57BL/6J" ;
  hcm-bio:hasHousingAssignment ex:housing-assignment-example-hcm .

ex:housing-assignment-example-hcm a hcm-bio:HousingAssignment ;
  hcm-bio:assignedToEnclosure ex:enclosure-example-hcm .

ex:data-product-example-hcm a hcm-tech:TimeSeries ;
  rdfs:label "Example CSV activity output" ;
  dcterms:license "CC BY 4.0" ;
  hcm-tech:hasFileFormat "text/csv" ;
  hcm-tech:hasSamplingRate "4 Hz" ;
  hcm-tech:hasStoragePath "https://example.org/hcm-system/day-01.csv" .

ex:contributor-jane-doe a schema:Person ;
  schema:affiliation "Example Institute" ;
  schema:email "jane@example.org" ;
  schema:name "Jane Doe" ;
  schema:roleName "Researcher / PI" .
