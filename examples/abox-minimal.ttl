@prefix ex: <https://example.org/hcmo/minimal/> .
@prefix hcm: <https://w3id.org/hcmo/ontology/hcm#> .
@prefix hcm-bio: <https://w3id.org/hcmo/ontology/hcm/bio#> .
@prefix hcm-env: <https://w3id.org/hcmo/ontology/hcm/env#> .
@prefix hcm-obs: <https://w3id.org/hcmo/ontology/hcm/obs#> .
@prefix hcm-tech: <https://w3id.org/hcmo/ontology/hcm/tech#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:cage-12 a hcm:MonitoredEnclosure ;
  rdfs:label "Rack 3, cage 12" ;
  hcm:hasEnclosureIdentifier "rack-3-cage-12" ;
  hcm:hasDimensions ex:cage-12-dimensions ;
  hcm:hasMonitoredAnimals ex:mouse-1 ;
  hcm-env:hasEnvironment ex:cage-12-environment ;
  hcm-tech:monitoredBy ex:ir-sensor-1 .

ex:cage-12-dimensions a hcm:EnclosureDimensions ;
  hcm:hasWidth 30.0 ;
  hcm:hasLength 45.0 ;
  hcm:hasHeight 20.0 ;
  hcm:hasDimUnit "cm" .

ex:cage-12-environment a hcm-env:EnvironmentProfile ;
  hcm-env:hasMeasurementSpec ex:activity-specification .

ex:activity-specification a hcm-env:MeasurementSpecification ;
  rdfs:label "Activity index measurement specification" .

ex:mouse-1 a hcm-bio:Subject ;
  rdfs:label "Mouse 1" ;
  hcm-bio:hasSpecies "Mus musculus" ;
  hcm-bio:hasStrain "C57BL/6J" ;
  hcm-bio:hasHousingAssignment ex:mouse-1-cage-12-assignment ;
  hcm-bio:hasBehaviorObservation ex:observation-1 .

ex:mouse-1-cage-12-assignment a hcm-bio:HousingAssignment ;
  hcm-bio:assignedToEnclosure ex:cage-12 .

ex:ir-sensor-1 a hcm-tech:Sensor ;
  rdfs:label "Left-wall infrared sensor" ;
  hcm-tech:hasSensorIdentifier "ir-1" ;
  hcm-tech:hasSensorType "infrared beam-break sensor" ;
  hcm-tech:hasSamplingRate "4 Hz" ;
  hcm-tech:installedIn ex:cage-12 ;
  hcm-tech:captures ex:locomotor-activity .

ex:locomotor-activity a sosa:Property ;
  rdfs:label "locomotor activity" .

ex:observation-1 a hcm-obs:BehaviorObservation ;
  sosa:hasFeatureOfInterest ex:mouse-1 ;
  sosa:madeBySensor ex:ir-sensor-1 ;
  sosa:observedProperty ex:locomotor-activity ;
  sosa:hasResult ex:behavior-result-1 ;
  sosa:phenomenonTime ex:observation-interval-1 ;
  hcm-obs:hasCondition ex:limited-human-interaction ;
  hcm-obs:occursIn ex:cage-12 .

ex:observation-interval-1 a time:Interval ;
  time:numericDuration 24.0 ;
  time:unitType time:unitHour ;
  time:hasBeginning [ a time:Instant ;
    time:inXSDDateTime "2026-07-01T08:00:00Z"^^xsd:dateTime ] ;
  time:hasEnd [ a time:Instant ;
    time:inXSDDateTime "2026-07-02T08:00:00Z"^^xsd:dateTime ] .

ex:limited-human-interaction rdfs:label "limited human interaction" .

ex:behavior-result-1 a hcm-obs:BehaviorResult ;
  hcm-obs:hasBehaviorType "exploration" ;
  hcm-obs:hasConfidenceScore 0.95 .

ex:activity-series a hcm-tech:TimeSeries ;
  rdfs:label "Cage 12 activity series" ;
  hcm-tech:hasFileFormat "text/csv" ;
  hcm-tech:hasStoragePath "data/cage-12-activity.csv" .
