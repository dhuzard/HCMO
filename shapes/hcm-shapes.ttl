@prefix hcm: <https://w3id.org/hcmo/ontology/hcm#> .
@prefix hcm-bio: <https://w3id.org/hcmo/ontology/hcm/bio#> .
@prefix hcm-env: <https://w3id.org/hcmo/ontology/hcm/env#> .
@prefix hcm-obs: <https://w3id.org/hcmo/ontology/hcm/obs#> .
@prefix hcm-tech: <https://w3id.org/hcmo/ontology/hcm/tech#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

hcm:MonitoredEnclosureShape a sh:NodeShape ;
  sh:targetClass hcm:MonitoredEnclosure ;
  sh:property [
    sh:path rdfs:label ; sh:datatype xsd:string ; sh:minCount 1 ; sh:maxCount 1
  ] ;
  sh:property [
    sh:path hcm:hasEnclosureIdentifier ; sh:datatype xsd:string ; sh:minCount 1 ; sh:maxCount 1
  ] ;
  sh:property [
    sh:path hcm:hasDimensions ; sh:class hcm:EnclosureDimensions ; sh:minCount 1 ; sh:maxCount 1
  ] ;
  sh:property [
    sh:path hcm-tech:monitoredBy ; sh:class hcm-tech:Sensor ; sh:minCount 1
  ] ;
  sh:property [
    sh:path hcm:hasMonitoredAnimals ; sh:class hcm-bio:Subject ; sh:minCount 1
  ] ;
  sh:property [
    sh:path hcm-env:hasEnvironment ; sh:class hcm-env:EnvironmentProfile ; sh:maxCount 1
  ] .

hcm:EnclosureDimensionsShape a sh:NodeShape ;
  sh:targetClass hcm:EnclosureDimensions ;
  sh:property [
    sh:path hcm:hasWidth ; sh:datatype xsd:decimal ; sh:minExclusive 0 ; sh:minCount 1 ; sh:maxCount 1
  ] ;
  sh:property [
    sh:path hcm:hasLength ; sh:datatype xsd:decimal ; sh:minExclusive 0 ; sh:minCount 1 ; sh:maxCount 1
  ] ;
  sh:property [
    sh:path hcm:hasHeight ; sh:datatype xsd:decimal ; sh:minExclusive 0 ; sh:minCount 1 ; sh:maxCount 1
  ] ;
  sh:property [
    sh:path hcm:hasDimUnit ; sh:datatype xsd:string ; sh:minCount 1 ; sh:maxCount 1
  ] .

hcm-bio:SubjectShape a sh:NodeShape ;
  sh:targetClass hcm-bio:Subject ;
  sh:property [
    sh:path rdfs:label ; sh:datatype xsd:string ; sh:minCount 1 ; sh:maxCount 1
  ] ;
  sh:property [
    sh:path hcm-bio:hasSpecies ; sh:datatype xsd:string ; sh:minCount 1 ; sh:maxCount 1
  ] ;
  sh:property [
    sh:path hcm-bio:hasHousingAssignment ; sh:class hcm-bio:HousingAssignment ; sh:minCount 1
  ] .

hcm-bio:HousingAssignmentShape a sh:NodeShape ;
  sh:targetClass hcm-bio:HousingAssignment ;
  sh:property [
    sh:path hcm-bio:assignedToEnclosure ; sh:class hcm:MonitoredEnclosure ; sh:minCount 1 ; sh:maxCount 1
  ] .

hcm-tech:SensorShape a sh:NodeShape ;
  sh:targetClass hcm-tech:Sensor ;
  sh:property [
    sh:path rdfs:label ; sh:datatype xsd:string ; sh:minCount 1
  ] ;
  sh:property [
    sh:path hcm-tech:hasSensorIdentifier ; sh:datatype xsd:string ; sh:minCount 1 ; sh:maxCount 1
  ] ;
  sh:property [
    sh:path hcm-tech:installedIn ; sh:class hcm:MonitoredEnclosure ; sh:minCount 1 ; sh:maxCount 1
  ] .

hcm-obs:BehaviorObservationShape a sh:NodeShape ;
  sh:targetClass hcm-obs:BehaviorObservation ;
  sh:property [
    sh:path sosa:hasFeatureOfInterest ; sh:class hcm-bio:Subject ; sh:minCount 1 ; sh:maxCount 1
  ] ;
  sh:property [
    sh:path sosa:madeBySensor ; sh:class hcm-tech:Sensor ; sh:minCount 1 ; sh:maxCount 1
  ] ;
  sh:property [
    sh:path sosa:hasResult ; sh:class hcm-obs:BehaviorResult ; sh:minCount 1 ; sh:maxCount 1
  ] ;
  sh:property [
    sh:path hcm-obs:occursIn ; sh:class hcm:MonitoredEnclosure ; sh:minCount 1 ; sh:maxCount 1
  ] .

hcm-obs:QuantityValueShape a sh:NodeShape ;
  sh:targetClass hcm-obs:QuantityValue ;
  sh:property [
    sh:path hcm-obs:hasNumericValue ; sh:datatype xsd:decimal ; sh:minCount 1 ; sh:maxCount 1
  ] ;
  sh:property [
    sh:path hcm:hasUnit ; sh:datatype xsd:string ; sh:minCount 1 ; sh:maxCount 1
  ] .

hcm-tech:TimeSeriesShape a sh:NodeShape ;
  sh:targetClass hcm-tech:TimeSeries ;
  sh:property [
    sh:path hcm-tech:hasFileFormat ; sh:datatype xsd:string ; sh:minCount 1
  ] ;
  sh:property [
    sh:path hcm-tech:hasStoragePath ; sh:datatype xsd:string ; sh:minCount 1
  ] .
