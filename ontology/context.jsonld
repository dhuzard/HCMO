{
  "@context": {
    "@vocab": "https://w3id.org/hcmo/ontology/hcm#",
    "hcm": "https://w3id.org/hcmo/ontology/hcm#",
    "hcm-bio": "https://w3id.org/hcmo/ontology/hcm/bio#",
    "hcm-env": "https://w3id.org/hcmo/ontology/hcm/env#",
    "hcm-obs": "https://w3id.org/hcmo/ontology/hcm/obs#",
    "hcm-tech": "https://w3id.org/hcmo/ontology/hcm/tech#",
    "sosa": "http://www.w3.org/ns/sosa/",
    "time": "http://www.w3.org/2006/time#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "hasCapacity": { "@id": "hcm:hasCapacity", "@type": "xsd:nonNegativeInteger" },
    "hasHeight": { "@id": "hcm:hasHeight", "@type": "xsd:decimal" },
    "hasLength": { "@id": "hcm:hasLength", "@type": "xsd:decimal" },
    "hasWidth": { "@id": "hcm:hasWidth", "@type": "xsd:decimal" },
    "isOccupied": { "@id": "hcm:isOccupied", "@type": "xsd:boolean" },
    "isOperational": { "@id": "hcm:isOperational", "@type": "xsd:boolean" },

    "hasDimensions": { "@id": "hcm:hasDimensions", "@type": "@id" },
    "hasMonitoredAnimals": { "@id": "hcm:hasMonitoredAnimals", "@type": "@id" },
    "hasEnvironment": { "@id": "hcm-env:hasEnvironment", "@type": "@id" },
    "hasHousingAssignment": { "@id": "hcm-bio:hasHousingAssignment", "@type": "@id" },
    "assignedToEnclosure": { "@id": "hcm-bio:assignedToEnclosure", "@type": "@id" },
    "belongsToGroup": { "@id": "hcm-bio:belongsToGroup", "@type": "@id" },
    "monitoredBy": { "@id": "hcm-tech:monitoredBy", "@type": "@id" },
    "installedIn": { "@id": "hcm-tech:installedIn", "@type": "@id" },
    "hasActuator": { "@id": "hcm-tech:hasActuator", "@type": "@id" },
    "hasFeatureOfInterest": { "@id": "sosa:hasFeatureOfInterest", "@type": "@id" },
    "hasResult": { "@id": "sosa:hasResult", "@type": "@id" },
    "madeBySensor": { "@id": "sosa:madeBySensor", "@type": "@id" },
    "observedProperty": { "@id": "sosa:observedProperty", "@type": "@id" },
    "phenomenonTime": { "@id": "sosa:phenomenonTime", "@type": "@id" }
  }
}
