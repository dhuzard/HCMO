# HCMO v2 (re-modularised draft, bio) — bio — subjects, groups, housing assignment, study factors
# Generated for co-author review; see docs/paper/MODULE-MAP.md. Namespace policy: …/hcm/bio#.
#
@prefix hcm: <https://w3id.org/hcmo/ontology/hcm#> .
@prefix hcm-bio: <https://w3id.org/hcmo/ontology/hcm/bio#> .
@prefix hcm-obs: <https://w3id.org/hcmo/ontology/hcm/obs#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

hcm-bio:ExperimentalGroup a owl:Class ;
    rdfs:label "Experimental Group" ;
    rdfs:comment "A group of biological subjects sharing an experimental condition, treatment, or study role." .

hcm-bio:HousingAssignment a owl:Class ;
    rdfs:label "Housing Assignment" ;
    rdfs:comment "A record assigning a subject or group to an enclosure in a study or housing context." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hcm-bio:assignedToEnclosure ;
            owl:someValuesFrom hcm:MonitoredEnclosure ] .

hcm-bio:StudyFactors a owl:Class ;
    rdfs:label "Study Factors" ;
    rdfs:comment "A collection of experimental or husbandry factors that may affect subjects, housing, or observations." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hcm-bio:hasTreatment ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ] .

hcm-bio:SubjectObservationBearer a owl:Class ;
    rdfs:label "Subject Observation Bearer" ;
    rdfs:comment "A subject-level or enclosure-level entity that can bear observations about animals housed or monitored in it." .

hcm-bio:Subject a owl:Class ;
    rdfs:label "Subject" ;
    rdfs:comment "A biological individual, such as a laboratory animal, observed in a home-cage monitoring context." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom hcm-obs:BehaviorObservation ;
            owl:onProperty hcm-bio:hasBehaviorObservation ] .

hcm-bio:assignedToEnclosure a owl:ObjectProperty ;
    rdfs:label "assigned to enclosure" ;
    rdfs:comment "Relates a housing assignment to the enclosure or monitored enclosure involved in that assignment." ;
    rdfs:domain hcm-bio:HousingAssignment ;
    rdfs:range hcm:MonitoredEnclosure ;
    owl:inverseOf hcm-bio:hasAssignedHousing .

hcm-bio:belongsToGroup a owl:ObjectProperty ;
    rdfs:label "belongs to group" ;
    rdfs:comment "Relates a subject, assignment, or monitored enclosure context to an experimental group." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-bio:Subject hcm-bio:HousingAssignment hcm:MonitoredEnclosure ) ] ;
    rdfs:range hcm-bio:ExperimentalGroup ;
    owl:inverseOf hcm-bio:hasGroupContext .

hcm-bio:hasBiologicalSex a owl:DatatypeProperty ;
    rdfs:label "has biological sex" ;
    rdfs:comment "Records the biological sex reported for a subject." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-bio:Subject hcm:MonitoredEnclosure ) ] ;
    rdfs:range xsd:string .

hcm-bio:hasDateOfBirth a owl:DatatypeProperty ;
    rdfs:label "has date of birth" ;
    rdfs:comment "Records the date of birth reported for a subject." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-bio:Subject hcm:MonitoredEnclosure ) ] ;
    rdfs:range xsd:string .

hcm-bio:hasHealthStatusObservation a owl:ObjectProperty ;
    rdfs:label "has health status observation" ;
    rdfs:comment "Relates a subject to a health-status observation about that subject." ;
    rdfs:domain hcm-bio:SubjectObservationBearer ;
    rdfs:range hcm-obs:HealthStatusObservation ;
    owl:inverseOf hcm-bio:isHealthStatusObservationOf .

hcm-bio:hasHousingAssignment a owl:ObjectProperty ;
    rdfs:label "has housing assignment" ;
    rdfs:comment "Relates a subject or group to a housing assignment record." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-bio:Subject hcm-bio:ExperimentalGroup ) ] ;
    rdfs:range hcm-bio:HousingAssignment ;
    owl:inverseOf hcm-bio:isHousingAssignmentOf .

hcm-bio:hasMember a owl:ObjectProperty ;
    rdfs:label "has member" ;
    rdfs:comment "Relates an experimental group to a subject that is a member of the group." ;
    rdfs:domain hcm-bio:ExperimentalGroup ;
    rdfs:range hcm-bio:Subject ;
    owl:inverseOf hcm-bio:isMemberOf .

hcm-bio:hasSpecies a owl:DatatypeProperty ;
    rdfs:label "has species" ;
    rdfs:comment "Records the species name or identifier reported for a subject." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-bio:Subject hcm:MonitoredEnclosure ) ] ;
    rdfs:range xsd:string .

hcm-bio:hasSocialRequirement a owl:DatatypeProperty ;
    rdfs:label "has social requirement" ;
    rdfs:comment "Records a social housing or care requirement for a subject or experimental group." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-bio:Subject hcm-bio:ExperimentalGroup ) ] ;
    rdfs:range xsd:string .

hcm-bio:hasStrain a owl:DatatypeProperty ;
    rdfs:label "has strain" ;
    rdfs:comment "Records the strain, line, or breed reported for a subject." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-bio:Subject hcm:MonitoredEnclosure ) ] ;
    rdfs:range xsd:string .

hcm-bio:hasTreatment a owl:DatatypeProperty ;
    rdfs:label "has treatment" ;
    rdfs:comment "Records a treatment, intervention, or experimental condition assigned to a subject or group." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-bio:Subject hcm-bio:ExperimentalGroup hcm-bio:StudyFactors ) ] ;
    rdfs:range xsd:string .

hcm-bio:hasWeightObservation a owl:ObjectProperty ;
    rdfs:label "has weight observation" ;
    rdfs:comment "Relates a subject to a weight observation about that subject." ;
    rdfs:domain hcm-bio:SubjectObservationBearer ;
    rdfs:range hcm-obs:WeightObservation ;
    owl:inverseOf hcm-bio:isWeightObservationOf .

hcm-bio:hasBehaviorObservation a owl:ObjectProperty ;
    rdfs:label "has behavior observation" ;
    rdfs:comment "Relates a subject to a behavior observation about that subject." ;
    rdfs:domain hcm-bio:SubjectObservationBearer ;
    rdfs:range hcm-obs:BehaviorObservation ;
    owl:inverseOf hcm-bio:isBehaviorObservationOf .

hcm-bio:hasAssignedHousing a owl:ObjectProperty ;
    rdfs:label "has assigned housing" ;
    rdfs:comment "Inverse relation from a monitored enclosure to a housing assignment involving that enclosure." ;
    rdfs:domain hcm:MonitoredEnclosure ;
    rdfs:range hcm-bio:HousingAssignment ;
    owl:inverseOf hcm-bio:assignedToEnclosure .

hcm-bio:hasGroupContext a owl:ObjectProperty ;
    rdfs:label "has group context" ;
    rdfs:comment "Inverse relation from an experimental group to a subject, assignment, or monitored enclosure context belonging to it." ;
    rdfs:domain hcm-bio:ExperimentalGroup ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( hcm-bio:Subject hcm-bio:HousingAssignment hcm:MonitoredEnclosure ) ] ;
    owl:inverseOf hcm-bio:belongsToGroup .

hcm-bio:isBehaviorObservationOf a owl:ObjectProperty ;
    rdfs:label "is behavior observation of" ;
    rdfs:comment "Inverse relation from a behavior observation to the subject it observes." ;
    rdfs:domain hcm-obs:BehaviorObservation ;
    rdfs:range hcm-bio:SubjectObservationBearer ;
    owl:inverseOf hcm-bio:hasBehaviorObservation .

hcm-bio:isHealthStatusObservationOf a owl:ObjectProperty ;
    rdfs:label "is health status observation of" ;
    rdfs:comment "Inverse relation from a health-status observation to the subject it observes." ;
    rdfs:domain hcm-obs:HealthStatusObservation ;
    rdfs:range hcm-bio:SubjectObservationBearer ;
    owl:inverseOf hcm-bio:hasHealthStatusObservation .

hcm-bio:isHousingAssignmentOf a owl:ObjectProperty ;
    rdfs:label "is housing assignment of" ;
    rdfs:comment "Inverse relation from a housing assignment record to the subject or group it assigns." ;
    rdfs:domain hcm-bio:HousingAssignment ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( hcm-bio:Subject hcm-bio:ExperimentalGroup ) ] ;
    owl:inverseOf hcm-bio:hasHousingAssignment .

hcm-bio:isMemberOf a owl:ObjectProperty ;
    rdfs:label "is member of" ;
    rdfs:comment "Inverse relation from a subject to an experimental group in which it is a member." ;
    rdfs:domain hcm-bio:Subject ;
    rdfs:range hcm-bio:ExperimentalGroup ;
    owl:inverseOf hcm-bio:hasMember .

hcm-bio:isWeightObservationOf a owl:ObjectProperty ;
    rdfs:label "is weight observation of" ;
    rdfs:comment "Inverse relation from a weight observation to the subject it observes." ;
    rdfs:domain hcm-obs:WeightObservation ;
    rdfs:range hcm-bio:SubjectObservationBearer ;
    owl:inverseOf hcm-bio:hasWeightObservation .

