# HCMO v2 (re-modularised draft, tech) — tech — devices & data (Sensor/Hardware/Software/TimeSeries) — NEW module
# Generated for co-author review; see docs/paper/MODULE-MAP.md. Namespace policy: …/hcm/tech#.
#
@prefix hcm: <https://w3id.org/hcmo/ontology/hcm#> .
@prefix hcm-obs: <https://w3id.org/hcmo/ontology/hcm/obs#> .
@prefix hcm-tech: <https://w3id.org/hcmo/ontology/hcm/tech#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

hcm-tech:Hardware a owl:Class ;
    rdfs:label "Hardware" ;
    rdfs:comment "Physical computing hardware component of a home-cage monitoring system." ;
    owl:disjointWith hcm-tech:Software ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hcm-tech:supportsEnclosure ;
            owl:someValuesFrom hcm:MonitoredEnclosure ] .

hcm-tech:Actuator a owl:Class ;
    rdfs:label "Actuator" ;
    rdfs:comment "A device that elicits or perturbs behavior, physiology, or the monitored environment." .

hcm-tech:Sensor a owl:Class ;
    rdfs:label "Sensor" ;
    rdfs:comment "A device that captures signals related to behavior, physiology, or enclosure environment." ;
    owl:disjointWith hcm-tech:Actuator ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hcm-tech:installedIn ;
            owl:someValuesFrom hcm:MonitoredEnclosure ] .

hcm-tech:Software a owl:Class ;
    rdfs:label "Software" ;
    rdfs:comment "Software component used to acquire, process, store, or analyse home-cage monitoring data." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hcm-tech:runsOn ;
            owl:someValuesFrom hcm-tech:Hardware ] .

hcm-tech:TimeSeries a owl:Class ;
    rdfs:label "Time Series" ;
    rdfs:comment "An ordered sequence of time-indexed measurements or outputs produced in a monitoring workflow." ;
    rdfs:subClassOf hcm-obs:ObservationResult .

hcm-tech:hasFileFormat a owl:DatatypeProperty ;
    rdfs:label "has file format" ;
    rdfs:comment "Records the file format of a data, software, or time-series artifact." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-tech:Software hcm-tech:TimeSeries ) ] ;
    rdfs:range xsd:string .

hcm-tech:hasFirmware a owl:DatatypeProperty ;
    rdfs:label "has firmware" ;
    rdfs:comment "Records the firmware identifier or version installed on a hardware or sensor component." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-tech:Hardware hcm-tech:Sensor ) ] ;
    rdfs:range xsd:string .

hcm-tech:hasModelNumber a owl:DatatypeProperty ;
    rdfs:label "has model number" ;
    rdfs:comment "Records the manufacturer model number for a hardware, sensor, or actuator component." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-tech:Hardware hcm-tech:Sensor hcm-tech:Actuator ) ] ;
    rdfs:range xsd:string .

hcm-tech:hasProtocol a owl:DatatypeProperty ;
    rdfs:label "has protocol" ;
    rdfs:comment "Records the communication, acquisition, or processing protocol used by a technical component." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-tech:Hardware hcm-tech:Sensor hcm-tech:Software ) ] ;
    rdfs:range xsd:string .

hcm-tech:hasSamplingRate a owl:DatatypeProperty ;
    rdfs:label "has sampling rate" ;
    rdfs:comment "Records the rate at which a sensor or data stream is sampled." ;
    rdfs:domain hcm-tech:Sensor ;
    rdfs:range xsd:string .

hcm-tech:hasSensorIdentifier a owl:DatatypeProperty ;
    rdfs:label "has sensor identifier" ;
    rdfs:comment "Records an identifier assigned to a sensor." ;
    rdfs:domain hcm-tech:Sensor ;
    rdfs:range xsd:string .

hcm-tech:hasSensorTechnology a owl:DatatypeProperty ;
    rdfs:label "has sensor technology" ;
    rdfs:comment "Records the sensing technology or modality used by a sensor." ;
    rdfs:domain hcm-tech:Sensor ;
    rdfs:range xsd:string .

hcm-tech:hasSensorType a owl:DatatypeProperty ;
    rdfs:label "has sensor type" ;
    rdfs:comment "Records the functional type or category of a sensor." ;
    rdfs:domain hcm-tech:Sensor ;
    rdfs:range xsd:string .

hcm-tech:hasStoragePath a owl:DatatypeProperty ;
    rdfs:label "has storage path" ;
    rdfs:comment "Records a path or locator for stored data, software, or time-series resources." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-tech:Software hcm-tech:TimeSeries ) ] ;
    rdfs:range xsd:string .

hcm-tech:hasVersion a owl:DatatypeProperty ;
    rdfs:label "has version" ;
    rdfs:comment "Records a version string for software, firmware, hardware, or data artifacts." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-tech:Hardware hcm-tech:Sensor hcm-tech:Software hcm-tech:TimeSeries ) ] ;
    rdfs:range xsd:string .

hcm-tech:isCalibrated a owl:DatatypeProperty ;
    rdfs:label "is calibrated" ;
    rdfs:comment "Indicates whether a sensor or device has been calibrated." ;
    rdfs:domain hcm-tech:Sensor ;
    rdfs:range xsd:boolean .

hcm-tech:communicatesWith a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "communicates with" ;
    rdfs:comment "Relates a technical component to another hardware or software component with which it exchanges data or commands." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-tech:Hardware hcm-tech:Sensor hcm-tech:Actuator hcm-tech:Software ) ] ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( hcm-tech:Hardware hcm-tech:Sensor hcm-tech:Actuator hcm-tech:Software ) ] .

hcm-tech:captures a owl:ObjectProperty ;
    rdfs:label "captures" ;
    rdfs:comment "Relates a sensor or monitoring component to the behavior, physiology, environment, or signal it captures." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-tech:Sensor hcm-tech:Hardware hcm-tech:Software ) ] ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( hcm-obs:BehaviorObservation hcm-obs:EnvironmentObservation hcm-obs:HealthStatusObservation hcm-obs:WeightObservation hcm-obs:ObservationResult ) ] ;
    owl:inverseOf hcm-tech:isCapturedBy .

hcm-tech:hasActuator a owl:ObjectProperty ;
    rdfs:label "has actuator" ;
    rdfs:comment "Relates a monitoring setup or technical component to an actuator associated with it." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm:MonitoredEnclosure hcm-tech:Hardware hcm-tech:Sensor ) ] ;
    rdfs:range hcm-tech:Actuator ;
    owl:inverseOf hcm-tech:isActuatorOf .

hcm-tech:monitoredBy a owl:ObjectProperty ;
    rdfs:label "monitored by" ;
    rdfs:comment "Relates a monitored enclosure, subject, process, or property to the sensor or monitoring component observing it." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm:MonitoredEnclosure hcm-obs:ObservationResult ) ] ;
    rdfs:range hcm-tech:Sensor ;
    owl:inverseOf hcm-tech:monitors .

hcm-tech:installedIn a owl:ObjectProperty ;
    rdfs:label "installed in" ;
    rdfs:comment "Relates a sensor or technical component to the monitored enclosure or setup in which it is installed." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-tech:Sensor hcm-tech:Hardware ) ] ;
    rdfs:range hcm:MonitoredEnclosure ;
    owl:inverseOf hcm-tech:hasInstalledComponent .

hcm-tech:runsOn a owl:ObjectProperty ;
    rdfs:label "runs on" ;
    rdfs:comment "Relates software to the hardware or platform on which it executes." ;
    rdfs:domain hcm-tech:Software ;
    rdfs:range hcm-tech:Hardware ;
    owl:inverseOf hcm-tech:runsSoftware .

hcm-tech:supportsEnclosure a owl:ObjectProperty ;
    rdfs:label "supports enclosure" ;
    rdfs:comment "Relates a technical component or system to the monitored enclosure that it supports." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-tech:Hardware hcm-tech:Sensor hcm-tech:Software ) ] ;
    rdfs:range hcm:MonitoredEnclosure ;
    owl:inverseOf hcm-tech:isSupportedBy .

hcm-tech:hasInstalledComponent a owl:ObjectProperty ;
    rdfs:label "has installed component" ;
    rdfs:comment "Inverse relation from a monitored enclosure to a sensor or hardware component installed in it." ;
    rdfs:domain hcm:MonitoredEnclosure ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( hcm-tech:Sensor hcm-tech:Hardware ) ] ;
    owl:inverseOf hcm-tech:installedIn .

hcm-tech:isActuatorOf a owl:ObjectProperty ;
    rdfs:label "is actuator of" ;
    rdfs:comment "Inverse relation from an actuator to the monitoring setup or technical component associated with it." ;
    rdfs:domain hcm-tech:Actuator ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( hcm:MonitoredEnclosure hcm-tech:Hardware hcm-tech:Sensor ) ] ;
    owl:inverseOf hcm-tech:hasActuator .

hcm-tech:isCapturedBy a owl:ObjectProperty ;
    rdfs:label "is captured by" ;
    rdfs:comment "Inverse relation from an observation, result, or signal-like output to the sensor or monitoring component that captures it." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-obs:BehaviorObservation hcm-obs:EnvironmentObservation hcm-obs:HealthStatusObservation hcm-obs:WeightObservation hcm-obs:ObservationResult ) ] ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( hcm-tech:Sensor hcm-tech:Hardware hcm-tech:Software ) ] ;
    owl:inverseOf hcm-tech:captures .

hcm-tech:isSupportedBy a owl:ObjectProperty ;
    rdfs:label "is supported by" ;
    rdfs:comment "Inverse relation from a monitored enclosure to a technical component or system that supports it." ;
    rdfs:domain hcm:MonitoredEnclosure ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( hcm-tech:Hardware hcm-tech:Sensor hcm-tech:Software ) ] ;
    owl:inverseOf hcm-tech:supportsEnclosure .

hcm-tech:monitors a owl:ObjectProperty ;
    rdfs:label "monitors" ;
    rdfs:comment "Inverse relation from a sensor to the enclosure or observation result that it monitors." ;
    rdfs:domain hcm-tech:Sensor ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( hcm:MonitoredEnclosure hcm-obs:ObservationResult ) ] ;
    owl:inverseOf hcm-tech:monitoredBy .

hcm-tech:runsSoftware a owl:ObjectProperty ;
    rdfs:label "runs software" ;
    rdfs:comment "Inverse relation from hardware to software that runs on it." ;
    rdfs:domain hcm-tech:Hardware ;
    rdfs:range hcm-tech:Software ;
    owl:inverseOf hcm-tech:runsOn .

