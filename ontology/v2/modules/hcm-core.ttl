# HCMO v2 (re-modularised draft, core) — core — the MonitoredEnclosure hub + reused-vocab scaffolding + ontology header
# Generated for co-author review; see docs/paper/MODULE-MAP.md. Namespace policy: …/hcm#.
#
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hcm: <https://w3id.org/hcmo/ontology/hcm#> .
@prefix hcm-bio: <https://w3id.org/hcmo/ontology/hcm/bio#> .
@prefix hcm-env: <https://w3id.org/hcmo/ontology/hcm/env#> .
@prefix hcm-obs: <https://w3id.org/hcmo/ontology/hcm/obs#> .
@prefix hcm-tech: <https://w3id.org/hcmo/ontology/hcm/tech#> .
@prefix mod: <https://w3id.org/mod#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix semts: <https://w3id.org/semts/ontology/120#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dc:creator a owl:AnnotationProperty .

dc:description a owl:AnnotationProperty .

dc:title a owl:AnnotationProperty .

owl:versionInfo a owl:AnnotationProperty .

sosa:hasFeatureOfInterest a owl:ObjectProperty ;
    rdfs:label "has feature of interest" .

sosa:madeBySensor a owl:ObjectProperty ;
    rdfs:label "made by sensor" .

<https://w3id.org/hcmo/ontology/hcm> a owl:Ontology ;
    dc:description "Ontology for home-cage monitoring of laboratory animals" ;
    dc:title "Home-Cage Monitoring Ontology" ;
    dcterms:creator <https://orcid.org/0000-0002-2923-9790>,
        <https://orcid.org/0000-0002-6085-6818>,
        <https://orcid.org/0000-0002-9116-6692>,
        <https://orcid.org/0000-0003-2204-2466>,
        <https://orcid.org/0000-0003-4820-7951>,
        <https://orcid.org/0009-0008-0575-8490>,
        <https://orcid.org/0009-0008-2489-8106> ;
    owl:versionIRI <https://w3id.org/hcmo/ontology/hcm/0.0.1> ;
    owl:versionInfo "0.0.1" ;
    mod:createdWith <https://chowlk.linkeddata.es/> .

hcm:Enclosure a owl:DatatypeProperty ;
    rdfs:label "enclosure" ;
    rdfs:domain hcm:MonitoredEnclosure .

hcm:Enrichment a owl:Class ;
    rdfs:label "Enrichment" .

hcm:hasCapacity a owl:DatatypeProperty ;
    rdfs:label "has capacity" .

hcm:hasDescription a owl:DatatypeProperty ;
    rdfs:label "has description" .

hcm:hasMonitoredAnimals a owl:ObjectProperty ;
    rdfs:label "has monitored animals" .

hcm:hasName a owl:DatatypeProperty ;
    rdfs:label "has name" ;
    rdfs:range xsd:string .

hcm:isOccupied a owl:DatatypeProperty ;
    rdfs:label "is occupied" .

hcm:isOperational a owl:DatatypeProperty ;
    rdfs:label "is operational" .

semts:DataDimension a owl:Class ;
    rdfs:label "Data Dimension" .

semts:TimeSeriesSegment a owl:Class ;
    rdfs:label "Time Series Segment" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty semts:during ;
            owl:someValuesFrom time:TemporalEntity ],
        [ a owl:Restriction ;
            owl:onProperty semts:isPartOf ;
            owl:someValuesFrom hcm-obs:EnvironmentObservation ] .

semts:dimensionUnit a owl:DatatypeProperty ;
    rdfs:label "dimension unit" .

semts:generated a owl:ObjectProperty ;
    rdfs:label "generated" .

semts:hasDimension a owl:ObjectProperty ;
    rdfs:label "has dimension" .

semts:title a owl:DatatypeProperty ;
    rdfs:label "title" .

time:TemporalEntity a owl:Class ;
    rdfs:label "Temporal Entity" .

time:hasBeginning a owl:DatatypeProperty ;
    rdfs:label "has beginning" .

time:hasEnd a owl:DatatypeProperty ;
    rdfs:label "has end" .

time:inXSDDateTime a owl:DatatypeProperty ;
    rdfs:label "in x s d date time" .

sosa:hasResult a owl:ObjectProperty ;
    rdfs:label "has result" .

sosa:madeObservation a owl:ObjectProperty ;
    rdfs:label "made observation" .

sosa:phenomenonTime a owl:ObjectProperty ;
    rdfs:label "phenomenon time" .

<https://orcid.org/0000-0002-2923-9790> a schema:Person ;
    schema:name "Pierre Larmande" .

<https://orcid.org/0000-0002-6085-6818> a schema:Person ;
    schema:name "Serge Sonfack Sounchio" .

<https://orcid.org/0000-0002-9116-6692> a schema:Person ;
    schema:name "Konstantin Todorov" .

<https://orcid.org/0000-0003-2204-2466> a schema:Person ;
    schema:name "Gaoussou Sanou" .

<https://orcid.org/0000-0003-4820-7951> a schema:Person ;
    schema:name "Damien Huzard" .

<https://orcid.org/0009-0008-0575-8490> a schema:Person ;
    schema:name "Antoine Toffano" .

<https://orcid.org/0009-0008-2489-8106> a schema:Person ;
    schema:name "Cyril Gilbert" .

hcm:EnclosureDimensions a owl:Class ;
    rdfs:label "Enclosure Dimensions" .

hcm:hasDimUnit a owl:DatatypeProperty ;
    rdfs:label "has dim unit" .

hcm:hasDimensions a owl:ObjectProperty ;
    rdfs:label "has dimensions" .

hcm:hasEnclosureIdentifier a owl:DatatypeProperty ;
    rdfs:label "has enclosure identifier" .

hcm:hasEnrichment a owl:ObjectProperty ;
    rdfs:label "has enrichment" .

hcm:hasHeight a owl:DatatypeProperty ;
    rdfs:label "has height" .

hcm:hasLength a owl:DatatypeProperty ;
    rdfs:label "has length" .

hcm:hasManufacturer a owl:DatatypeProperty ;
    rdfs:label "has manufacturer" .

hcm:hasWidth a owl:DatatypeProperty ;
    rdfs:label "has width" .

hcm:locatedIn a owl:ObjectProperty ;
    rdfs:label "located in" .

semts:during a owl:ObjectProperty ;
    rdfs:label "during" .

semts:isPartOf a owl:ObjectProperty ;
    rdfs:label "is part of" .

sosa:observedProperty a owl:ObjectProperty ;
    rdfs:label "observed property" .

hcm:hasUnit a owl:DatatypeProperty ;
    rdfs:label "has unit" .

sosa:resultTime a owl:DatatypeProperty ;
    rdfs:label "result time" .

sosa:usedProcedure a owl:ObjectProperty ;
    rdfs:label "used procedure" .

hcm:MonitoredEnclosure a owl:Class ;
    rdfs:label "Monitored Enclosure" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom hcm-env:ThriveProfile ;
            owl:onProperty hcm-env:hasThriveProfile ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:isOperational ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:isOccupied ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty time:hasBeginning ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty time:hasEnd ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty time:inXSDDateTime ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:hasEnclosureIdentifier ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:hasManufacturer ],
        [ a owl:Restriction ;
            owl:allValuesFrom hcm-bio:ExperimentalGroup ;
            owl:onProperty hcm-bio:belongsToGroup ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:locatedIn ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:hasEnrichment ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:resultTime ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:phenomenonTime ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:usedProcedure ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-bio:hasDateOfBirth ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-bio:hasBiologicalSex ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-bio:hasStrain ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-bio:hasSpecies ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:resultTime ],
        [ a owl:Restriction ;
            owl:allValuesFrom hcm-obs:WeightObservation ;
            owl:onProperty hcm-bio:hasWeightObservation ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:observedProperty ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-obs:hasInterval ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:usedProcedure ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:observedProperty ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:hasResult ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:resultTime ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:usedProcedure ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-obs:hasHealthStatusTerm ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-obs:hasConfidenceScore ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-obs:hasNumericValue ],
        [ a owl:Restriction ;
            owl:allValuesFrom hcm-obs:HealthStatusObservation ;
            owl:onProperty hcm-bio:hasHealthStatusObservation ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:hasUnit ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-obs:hasBehaviorType ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-obs:hasConfidenceScore ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-env:hasGasType ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-env:hasValue ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:hasUnit ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:hasWidth ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:hasLength ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:hasHeight ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:hasDimUnit ],
        [ a owl:Restriction ;
            owl:onProperty hcm:hasDimensions ;
            owl:someValuesFrom hcm:EnclosureDimensions ],
        [ a owl:Restriction ;
            owl:onProperty hcm-tech:monitoredBy ;
            owl:someValuesFrom hcm-tech:Sensor ] .

