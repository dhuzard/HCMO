<https://orcid.org/0000-0003-4820-7951> a schema:Person ;
    schema:name "Damien Huzard" .

<https://orcid.org/0009-0008-0575-8490> a schema:Person ;
    schema:name "Antoine Toffano" .

<https://orcid.org/0009-0008-2489-8106> a schema:Person ;
    schema:name "Cyril Gilbert" .

hcm:EnclosureDimensions a owl:Class ;
    rdfs:label "Enclosure Dimensions" ;
    rdfs:comment "A dimensions record describing the physical size of an enclosure." .

hcm:hasDimUnit a owl:DatatypeProperty ;
    rdfs:label "has dim unit" ;
    rdfs:comment "Records the unit used for enclosure dimension values." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm:Enclosure hcm:EnclosureDimensions ) ] ;
    rdfs:range xsd:string .

hcm:hasDimensions a owl:ObjectProperty ;
    rdfs:label "has dimensions" ;
    rdfs:comment "Links a physical space or enclosure to its dimensions record." ;
    rdfs:domain hcm:Enclosure ;
    rdfs:range hcm:EnclosureDimensions .

hcm:hasEnclosureIdentifier a owl:DatatypeProperty ;
    rdfs:label "has enclosure identifier" ;
    rdfs:comment "Records the identifier assigned to an enclosure or monitored enclosure." ;
    rdfs:domain hcm:Enclosure ;
    rdfs:range xsd:string .

hcm:hasEnrichment a owl:ObjectProperty ;
    rdfs:label "has enrichment" ;
    rdfs:comment "Relates an enclosure or monitored enclosure to an enrichment present or specified for it." ;
    rdfs:domain hcm:Enclosure ;
    rdfs:range hcm:Enrichment .

hcm:hasEnrichmentType a owl:DatatypeProperty ;
    rdfs:label "has enrichment type" ;
    rdfs:comment "Records the type or category of enrichment associated with an enclosure." ;
    rdfs:domain hcm:Enrichment ;
    rdfs:range xsd:string .

hcm:hasFacilityType a owl:DatatypeProperty ;
    rdfs:label "has facility type" ;
    rdfs:comment "Records the type of facility or housing area associated with an enclosure." ;
    rdfs:domain hcm:Enclosure ;
    rdfs:range xsd:string .

hcm:hasFloorArea a owl:DatatypeProperty ;
    rdfs:label "has floor area" ;
    rdfs:comment "Records the floor area value for an enclosure or dimensions record." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm:Enclosure hcm:EnclosureDimensions ) ] ;
    rdfs:range xsd:decimal .

hcm:hasFoodRequirement a owl:DatatypeProperty ;
    rdfs:label "has food requirement" ;
    rdfs:comment "Records a textual or coded food-provision requirement for an enclosure or subject group." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm:Enclosure hcm-bio:ExperimentalGroup ) ] ;
    rdfs:range xsd:string .

hcm:hasHeight a owl:DatatypeProperty ;
    rdfs:label "has height" ;
    rdfs:comment "Records the height value of an enclosure or dimensions record." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm:Enclosure hcm:EnclosureDimensions ) ] ;
    rdfs:range xsd:decimal .

hcm:hasLength a owl:DatatypeProperty ;
    rdfs:label "has length" ;
    rdfs:comment "Records the length value of an enclosure or dimensions record." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm:Enclosure hcm:EnclosureDimensions ) ] ;
    rdfs:range xsd:decimal .

hcm:hasManufacturer a owl:DatatypeProperty ;
    rdfs:label "has manufacturer" ;
    rdfs:comment "Records the manufacturer name for an enclosure, device, or system component." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm:Enclosure hcm-tech:Hardware hcm-tech:Sensor hcm-tech:Actuator ) ] ;
    rdfs:range xsd:string .

hcm:hasSafetyRequirement a owl:DatatypeProperty ;
    rdfs:label "has safety requirement" ;
    rdfs:comment "Records a textual or coded safety requirement for an enclosure or monitoring setup." ;
    rdfs:domain hcm:Enclosure ;
    rdfs:range xsd:string .

hcm:hasWaterRequirement a owl:DatatypeProperty ;
    rdfs:label "has water requirement" ;
    rdfs:comment "Records a textual or coded water-provision requirement for an enclosure or subject group." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm:Enclosure hcm-bio:ExperimentalGroup ) ] ;
    rdfs:range xsd:string .

hcm:hasWidth a owl:DatatypeProperty ;
    rdfs:label "has width" ;
    rdfs:comment "Records the width value of an enclosure or dimensions record." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm:Enclosure hcm:EnclosureDimensions ) ] ;
    rdfs:range xsd:decimal .

hcm:locatedIn a owl:ObjectProperty ;
    rdfs:label "located in" ;
    rdfs:comment "Relates an enclosure or monitored enclosure to the facility, room, rack, or other location in which it is situated." .

semts:during a owl:ObjectProperty ;
    rdfs:label "during" ;
    rdfs:comment "SEMTS relation linking a data segment to the temporal entity during which it occurs." ;
    rdfs:domain semts:TimeSeriesSegment ;
    rdfs:range time:TemporalEntity .

semts:isPartOf a owl:ObjectProperty ;
    rdfs:label "is part of" ;
    rdfs:comment "SEMTS relation linking a data segment or artifact to the larger artifact it is part of." ;
    rdfs:domain semts:TimeSeriesSegment ;
    rdfs:range hcm-obs:EnvironmentObservation .

sosa:observedProperty a owl:ObjectProperty ;
    rdfs:label "observed property" ;
    rdfs:comment "SOSA relation linking an observation to the property being observed." .

hcm:hasUnit a owl:DatatypeProperty ;
    rdfs:label "has unit" ;
    rdfs:comment "Records the measurement unit associated with a quantitative value." ;
    rdfs:range xsd:string .

sosa:resultTime a owl:DatatypeProperty ;
    rdfs:label "result time" ;
    rdfs:comment "SOSA property recording the instant at which an observation result became available." ;
    rdfs:range xsd:dateTime .

sosa:usedProcedure a owl:ObjectProperty ;
    rdfs:label "used procedure" ;
    rdfs:comment "SOSA relation linking an observation to the procedure used to make it." .

hcm:MonitoredEnclosure a owl:Class ;
    rdfs:label "Monitored Enclosure" ;
    rdfs:comment "A monitored housing unit that links an enclosure identifier, timing, animals, environmental profiles, sensors, and observations in HCMO." ;
    rdfs:subClassOf hcm:Enclosure,
        [ a owl:Restriction ;
            owl:allValuesFrom hcm-env:ThriveProfile ;
            owl:onProperty hcm-env:hasThriveProfile ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:isOperational ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:isOccupied ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty time:hasBeginning ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty time:hasEnd ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty time:inXSDDateTime ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:hasEnclosureIdentifier ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:hasManufacturer ],
        [ a owl:Restriction ;
            owl:allValuesFrom hcm-bio:ExperimentalGroup ;
            owl:onProperty hcm-bio:belongsToGroup ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:locatedIn ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:hasEnrichment ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:resultTime ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:phenomenonTime ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:usedProcedure ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-bio:hasDateOfBirth ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-bio:hasBiologicalSex ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-bio:hasStrain ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-bio:hasSpecies ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:resultTime ],
        [ a owl:Restriction ;
            owl:allValuesFrom hcm-obs:WeightObservation ;
            owl:onProperty hcm-bio:hasWeightObservation ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:observedProperty ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-obs:hasInterval ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:usedProcedure ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:observedProperty ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:hasResult ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:resultTime ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:usedProcedure ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-obs:hasHealthStatusTerm ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-obs:hasConfidenceScore ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-obs:hasNumericValue ],
        [ a owl:Restriction ;
            owl:allValuesFrom hcm-obs:HealthStatusObservation ;
            owl:onProperty hcm-bio:hasHealthStatusObservation ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:hasUnit ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-obs:hasBehaviorType ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-obs:hasConfidenceScore ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-env:hasGasType ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-env:hasValue ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:hasUnit ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:hasWidth ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:hasLength ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:hasHeight ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:hasDimUnit ],
        [ a owl:Restriction ;
            owl:onProperty hcm:hasDimensions ;
            owl:someValuesFrom hcm:EnclosureDimensions ],
        [ a owl:Restriction ;
            owl:onProperty hcm-tech:monitoredBy ;
            owl:someValuesFrom hcm-tech:Sensor ] .

