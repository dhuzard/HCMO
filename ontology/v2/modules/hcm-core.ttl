bibo:doi a owl:AnnotationProperty .

dc:creator a owl:AnnotationProperty .

dc:description a owl:AnnotationProperty .

dc:title a owl:AnnotationProperty .

dcterms:bibliographicCitation a owl:AnnotationProperty .

dcterms:created a owl:AnnotationProperty .

dcterms:creator a owl:AnnotationProperty .

dcterms:identifier a owl:AnnotationProperty .

dcterms:issued a owl:AnnotationProperty .

dcterms:license a owl:AnnotationProperty .

dcterms:modified a owl:AnnotationProperty .

dcterms:publisher a owl:AnnotationProperty .

dcterms:source a owl:AnnotationProperty .

mod:createdWith a owl:AnnotationProperty .

mod:status a owl:AnnotationProperty .

owl:versionInfo a owl:AnnotationProperty .

schema:logo a owl:AnnotationProperty .

schema:Person a owl:Class ;
    rdfs:label "Person" ;
    rdfs:comment "Schema.org class used to identify HCMO contributors in ontology metadata." .

schema:name a owl:DatatypeProperty ;
    rdfs:label "name" ;
    rdfs:comment "Schema.org property used to record contributor names in HCMO ontology metadata." ;
    rdfs:domain schema:Person ;
    rdfs:range xsd:string .

vann:preferredNamespacePrefix a owl:AnnotationProperty .

vann:preferredNamespaceUri a owl:AnnotationProperty .

sosa:hasFeatureOfInterest a owl:ObjectProperty ;
    rdfs:label "has feature of interest" ;
    rdfs:comment "SOSA relation linking an observation to the entity, system, or feature being observed." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-obs:BehaviorObservation hcm-obs:EnvironmentObservation hcm-obs:HealthStatusObservation hcm-obs:WeightObservation ) ] ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( hcm:MonitoredEnclosure hcm-bio:Subject ) ] .

sosa:madeBySensor a owl:ObjectProperty ;
    rdfs:label "made by sensor" ;
    rdfs:comment "SOSA relation linking an observation to the sensor that made it." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-obs:BehaviorObservation hcm-obs:EnvironmentObservation hcm-obs:HealthStatusObservation hcm-obs:WeightObservation hcm-obs:ObservationResult ) ] ;
    rdfs:range hcm-tech:Sensor .

<https://w3id.org/hcmo/ontology/hcm> a owl:Ontology ;
    dc:description "Ontology for home-cage monitoring of laboratory animals" ;
    dc:title "Home-Cage Monitoring Ontology" ;
    bibo:doi "10.5281/zenodo.18925285" ;
    dcterms:bibliographicCitation "The Home-Cage Monitoring Ontology (HCMO), version 0.0.1. Zenodo. https://doi.org/10.5281/zenodo.18925285" ;
    dcterms:created "2026-03-09"^^xsd:date ;
    dcterms:creator <https://orcid.org/0000-0002-2923-9790>,
        <https://orcid.org/0000-0002-6085-6818>,
        <https://orcid.org/0000-0002-9116-6692>,
        <https://orcid.org/0000-0003-2204-2466>,
        <https://orcid.org/0000-0003-4820-7951>,
        <https://orcid.org/0009-0008-0575-8490>,
        <https://orcid.org/0009-0008-2489-8106> ;
    dcterms:identifier "https://doi.org/10.5281/zenodo.18925285" ;
    dcterms:issued "2026-03-09"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:modified "2026-07-09"^^xsd:date ;
    dcterms:publisher "Huzard group" ;
    dcterms:source <https://github.com/dhuzard/HCMO> ;
    owl:versionIRI <https://w3id.org/hcmo/ontology/hcm/0.0.1> ;
    owl:versionInfo "0.0.1" ;
    schema:logo <https://raw.githubusercontent.com/dhuzard/HCMO/main/HCMO-logo3.png> ;
    mod:createdWith <https://chowlk.linkeddata.es/> ;
    mod:status "draft" ;
    vann:preferredNamespacePrefix "hcm" ;
    vann:preferredNamespaceUri "https://w3id.org/hcmo/ontology/hcm#" .

hcm:Enclosure a owl:Class ;
    rdfs:label "Enclosure" ;
    rdfs:comment "A physical housing enclosure used as part of a home-cage monitoring system." .

hcm:Enrichment a owl:Class ;
    rdfs:label "Enrichment" ;
    rdfs:comment "A material, structure, or intervention provided within an enclosure to support animal welfare or experimental conditions." .

hcm:hasEnrichmentRequirement a owl:DatatypeProperty ;
    rdfs:label "has enrichment requirement" ;
    rdfs:comment "Records a textual or coded enrichment requirement for an enclosure or monitored enclosure." ;
    rdfs:domain hcm:Enclosure ;
    rdfs:range xsd:string .

hcm:hasCapacity a owl:DatatypeProperty ;
    rdfs:label "has capacity" ;
    rdfs:comment "Records the intended capacity of an enclosure, such as the number of animals it can house." ;
    rdfs:domain hcm:Enclosure ;
    rdfs:range xsd:string .

hcm:hasDescription a owl:DatatypeProperty ;
    rdfs:label "has description" ;
    rdfs:comment "Provides a textual description for an HCMO resource." .

hcm:hasMonitoredAnimals a owl:ObjectProperty ;
    rdfs:label "has monitored animals" ;
    rdfs:comment "Relates a monitored enclosure to the biological subjects housed or tracked within it." ;
    rdfs:domain hcm:MonitoredEnclosure ;
    rdfs:range hcm-bio:Subject .

hcm:hasName a owl:DatatypeProperty ;
    rdfs:label "has name" ;
    rdfs:comment "Records a human-readable name for an HCMO resource." ;
    rdfs:range xsd:string .

hcm:isOccupied a owl:DatatypeProperty ;
    rdfs:label "is occupied" ;
    rdfs:comment "Indicates whether an enclosure is currently occupied by animals." ;
    rdfs:domain hcm:MonitoredEnclosure ;
    rdfs:range xsd:boolean .

hcm:isOperational a owl:DatatypeProperty ;
    rdfs:label "is operational" ;
    rdfs:comment "Indicates whether a monitored enclosure or monitoring component is currently operational." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm:MonitoredEnclosure hcm-tech:Hardware hcm-tech:Sensor hcm-tech:Actuator hcm-tech:Software ) ] ;
    rdfs:range xsd:boolean .

semts:DataDimension a owl:Class ;
    rdfs:label "Data Dimension" ;
    rdfs:comment "SEMTS class used for dimensions of time-series or tabular data generated by an HCMO observation." .

semts:TimeSeriesSegment a owl:Class ;
    rdfs:label "Time Series Segment" ;
    rdfs:comment "SEMTS class used for a segment of time-series data generated by a monitoring output." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty semts:during ;
            owl:someValuesFrom time:TemporalEntity ],
        [ a owl:Restriction ;
            owl:onProperty semts:isPartOf ;
            owl:someValuesFrom hcm-obs:EnvironmentObservation ] .

semts:dimensionUnit a owl:DatatypeProperty ;
    rdfs:label "dimension unit" ;
    rdfs:comment "SEMTS property recording the unit associated with a data dimension." ;
    rdfs:domain semts:DataDimension ;
    rdfs:range xsd:string .

semts:generated a owl:ObjectProperty ;
    rdfs:label "generated" ;
    rdfs:comment "SEMTS relation linking a result artifact to generated data such as a time-series segment." ;
    rdfs:domain hcm-obs:ObservationResult ;
    rdfs:range semts:TimeSeriesSegment .

semts:hasDimension a owl:ObjectProperty ;
    rdfs:label "has dimension" ;
    rdfs:comment "SEMTS relation linking a data artifact or observation to one of its data dimensions." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-obs:EnvironmentObservation hcm-obs:ObservationResult ) ] ;
    rdfs:range semts:DataDimension .

semts:title a owl:DatatypeProperty ;
    rdfs:label "title" ;
    rdfs:comment "SEMTS property recording a title for a data artifact or dimension." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( semts:DataDimension semts:TimeSeriesSegment hcm-obs:ObservationResult ) ] ;
    rdfs:range xsd:string .

time:TemporalEntity a owl:Class ;
    rdfs:label "Temporal Entity" ;
    rdfs:comment "OWL-Time class used for temporal entities referenced by HCMO observations and time-series segments." .

time:hasBeginning a owl:ObjectProperty ;
    rdfs:label "has beginning" ;
    rdfs:comment "OWL-Time relation linking a temporal entity or monitoring interval to its beginning." .

time:hasEnd a owl:ObjectProperty ;
    rdfs:label "has end" ;
    rdfs:comment "OWL-Time relation linking a temporal entity or monitoring interval to its end." .

time:inXSDDateTime a owl:DatatypeProperty ;
    rdfs:label "in x s d date time" ;
    rdfs:comment "OWL-Time datatype property recording a date-time literal." .

sosa:hasResult a owl:ObjectProperty ;
    rdfs:label "has result" ;
    rdfs:comment "SOSA relation linking an observation to its result." .

sosa:madeObservation a owl:ObjectProperty ;
    rdfs:label "made observation" ;
    rdfs:comment "SOSA relation linking a sensor to an observation it made." ;
    rdfs:domain hcm-tech:Sensor ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( hcm-obs:BehaviorObservation hcm-obs:EnvironmentObservation hcm-obs:HealthStatusObservation hcm-obs:WeightObservation ) ] .

sosa:phenomenonTime a owl:ObjectProperty ;
    rdfs:label "phenomenon time" ;
    rdfs:comment "SOSA relation linking an observation to the time that the observed phenomenon occurred." .

<https://orcid.org/0000-0002-2923-9790> a schema:Person ;
    schema:name "Pierre Larmande" .

<https://orcid.org/0000-0002-6085-6818> a schema:Person ;
    schema:name "Serge Sonfack Sounchio" .

<https://orcid.org/0000-0002-9116-6692> a schema:Person ;
