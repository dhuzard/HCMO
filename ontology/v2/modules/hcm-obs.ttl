# HCMO v2 (re-modularised draft, obs) — obs — observations AND results (LocationResultTable, ObservationResult, QuantityValue, ...)
# Generated for co-author review; see docs/paper/MODULE-MAP.md. Namespace policy: …/hcm/obs#.
#
@prefix hcm: <https://w3id.org/hcmo/ontology/hcm#> .
@prefix hcm-bio: <https://w3id.org/hcmo/ontology/hcm/bio#> .
@prefix hcm-env: <https://w3id.org/hcmo/ontology/hcm/env#> .
@prefix hcm-obs: <https://w3id.org/hcmo/ontology/hcm/obs#> .
@prefix hcm-tech: <https://w3id.org/hcmo/ontology/hcm/tech#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix semts: <https://w3id.org/semts/ontology/120#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

hcm-obs:BehaviorObservation a owl:Class ;
    rdfs:label "Behavior Observation" ;
    rdfs:comment "A SOSA-style observation about the behavior of a subject in a home-cage monitoring context." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sosa:hasResult ;
            owl:someValuesFrom hcm-obs:BehaviorResult ],
        [ a owl:Restriction ;
            owl:onProperty sosa:hasFeatureOfInterest ;
            owl:someValuesFrom hcm-bio:Subject ] .

hcm-obs:BehaviorResult a owl:Class ;
    rdfs:label "Behavior Result" ;
    rdfs:comment "An observation result representing a detected, classified, or recorded behavior." .

hcm-obs:CategoricalResult a owl:Class ;
    rdfs:label "Categorical Result" ;
    rdfs:comment "An observation result represented by a category rather than a numeric value." ;
    rdfs:subClassOf hcm-obs:ObservationResult .

hcm-obs:EnvironmentObservation a owl:Class ;
    rdfs:label "Environment Observation" ;
    rdfs:comment "A SOSA-style observation about an environmental property of a monitored enclosure." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sosa:hasFeatureOfInterest ;
            owl:someValuesFrom hcm:MonitoredEnclosure ],
        [ a owl:Restriction ;
            owl:allValuesFrom semts:DataDimension ;
            owl:onProperty semts:hasDimension ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-obs:hasCategory ] .

hcm-obs:GasConcentrationObservation a owl:Class ;
    rdfs:label "Gas Concentration Observation" ;
    rdfs:comment "An environment observation measuring or reporting the concentration of a gas." ;
    rdfs:subClassOf hcm-obs:EnvironmentObservation .

hcm-obs:HealthStatusObservation a owl:Class ;
    rdfs:label "Health Status Observation" ;
    rdfs:comment "A SOSA-style observation about the health status of a biological subject." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sosa:hasFeatureOfInterest ;
            owl:someValuesFrom hcm-bio:Subject ] .

hcm-obs:ObservableProperty a owl:Class ;
    rdfs:label "Observable Property" ;
    rdfs:comment "A property, result, or parameter that can be used as the observed property of an HCMO observation." .

hcm-obs:ObservationContext a owl:Class ;
    rdfs:label "Observation Context" ;
    rdfs:comment "An observation-like context, including observations, results, or monitored-enclosure contexts that currently carry observation restrictions in the v2 draft." .

hcm-obs:LocationResultTable a owl:Class ;
    rdfs:label "Location Result Table" ;
    rdfs:comment "A tabular observation result containing location values or generated time-series segments." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sosa:hasResult ;
            owl:someValuesFrom hcm-obs:QuantityValue ],
        [ a owl:Restriction ;
            owl:onProperty semts:generated ;
            owl:someValuesFrom semts:TimeSeriesSegment ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:resultTime ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:phenomenonTime ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:usedProcedure ],
        hcm-obs:ObservationResult .

hcm-obs:WeightObservation a owl:Class ;
    rdfs:label "Weight Observation" ;
    rdfs:comment "A SOSA-style observation reporting the body weight of a biological subject." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:observedProperty ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:usedProcedure ],
        [ a owl:Restriction ;
            owl:onProperty sosa:hasFeatureOfInterest ;
            owl:someValuesFrom hcm-bio:Subject ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:resultTime ],
        hcm-obs:ObservationResult .

hcm-obs:hasBehaviorType a owl:DatatypeProperty ;
    rdfs:label "has behavior type" ;
    rdfs:comment "Records the behavior type or behavior category associated with a behavior observation or result." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm:MonitoredEnclosure hcm-obs:BehaviorObservation hcm-obs:BehaviorResult ) ] ;
    rdfs:range xsd:string .

hcm-obs:hasCondition a owl:ObjectProperty ;
    rdfs:label "has condition" ;
    rdfs:comment "Relates an observation to the condition under which it was made or interpreted." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-obs:BehaviorObservation hcm-obs:EnvironmentObservation hcm-obs:HealthStatusObservation hcm-obs:WeightObservation hcm-obs:ObservationResult ) ] ;
    rdfs:range hcm-obs:ObservationCondition ;
    owl:inverseOf hcm-obs:isConditionOf .

hcm-obs:hasConfidenceScore a owl:DatatypeProperty ;
    rdfs:label "has confidence score" ;
    rdfs:comment "Records a numeric confidence score associated with an observation or inferred result." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm:MonitoredEnclosure hcm-obs:BehaviorObservation hcm-obs:ObservationResult ) ] ;
    rdfs:range xsd:decimal .

hcm-obs:hasHealthStatusTerm a owl:DatatypeProperty ;
    rdfs:label "has health status term" ;
    rdfs:comment "Records a textual or coded health-status term associated with a health-status observation." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm:MonitoredEnclosure hcm-obs:HealthStatusObservation ) ] ;
    rdfs:range xsd:string .

hcm-obs:hasInterval a owl:DatatypeProperty ;
    rdfs:label "has interval" ;
    rdfs:comment "Records a time interval or duration associated with an observation or result." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm:MonitoredEnclosure hcm-obs:BehaviorObservation hcm-obs:EnvironmentObservation hcm-obs:HealthStatusObservation hcm-obs:WeightObservation hcm-obs:ObservationResult ) ] ;
    rdfs:range xsd:string .

hcm-obs:hasNumericValue a owl:DatatypeProperty ;
    rdfs:label "has numeric value" ;
    rdfs:comment "Records the numeric value of a quantity result or measurement." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm:MonitoredEnclosure hcm-obs:QuantityValue hcm-obs:ObservationResult hcm-obs:EnvironmentObservation ) ] ;
    rdfs:range xsd:decimal .

hcm-obs:occursIn a owl:ObjectProperty ;
    rdfs:label "occurs in" ;
    rdfs:comment "Relates an observation, result, or event to the enclosure or context in which it occurs." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-obs:BehaviorObservation hcm-obs:EnvironmentObservation hcm-obs:HealthStatusObservation hcm-obs:WeightObservation hcm-obs:ObservationResult ) ] ;
    rdfs:range hcm:MonitoredEnclosure ;
    owl:inverseOf hcm-obs:hasOccurrence .

hcm-obs:QuantityValue a owl:Class ;
    rdfs:label "Quantity Value" ;
    rdfs:comment "An observation result that represents a quantitative value, typically with a numeric value and unit." .

hcm-obs:hasCategory a owl:DatatypeProperty ;
    rdfs:label "has category" ;
    rdfs:comment "Records the category assigned to a categorical observation or result." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm:MonitoredEnclosure hcm-obs:CategoricalResult hcm-obs:ObservationResult hcm-obs:EnvironmentObservation ) ] ;
    rdfs:range xsd:string .

hcm-obs:hasResult a owl:ObjectProperty ;
    rdfs:label "has result" ;
    rdfs:comment "Relates an HCMO observation to its observation result." ;
    rdfs:domain hcm-obs:ObservationContext ;
    rdfs:range hcm-obs:ObservationResult ;
    owl:equivalentProperty sosa:hasResult .

hcm-obs:ObservationCondition a owl:Class ;
    rdfs:label "Observation Condition" ;
    rdfs:comment "A condition, state, or contextual qualifier under which an observation was made or interpreted." .

hcm-obs:ObservationResult a owl:Class ;
    rdfs:label "Observation Result" ;
    rdfs:comment "A result produced by an observation, optionally linked to the sensor that made or generated it." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom hcm-tech:Sensor ;
            owl:onProperty sosa:madeBySensor ] .

hcm-obs:hasOccurrence a owl:ObjectProperty ;
    rdfs:label "has occurrence" ;
    rdfs:comment "Inverse relation from a monitored enclosure to an observation, result, or event that occurs in it." ;
    rdfs:domain hcm:MonitoredEnclosure ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( hcm-obs:BehaviorObservation hcm-obs:EnvironmentObservation hcm-obs:HealthStatusObservation hcm-obs:WeightObservation hcm-obs:ObservationResult ) ] ;
    owl:inverseOf hcm-obs:occursIn .

hcm-obs:isConditionOf a owl:ObjectProperty ;
    rdfs:label "is condition of" ;
    rdfs:comment "Inverse relation from an observation condition to the observation or result qualified by it." ;
    rdfs:domain hcm-obs:ObservationCondition ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( hcm-obs:BehaviorObservation hcm-obs:EnvironmentObservation hcm-obs:HealthStatusObservation hcm-obs:WeightObservation hcm-obs:ObservationResult ) ] ;
    owl:inverseOf hcm-obs:hasCondition .

hcm-obs:isFeatureOfInterestOf a owl:ObjectProperty ;
    rdfs:label "is feature of interest of" ;
    rdfs:comment "Inverse relation from a subject or monitored enclosure to an observation for which it is the feature of interest." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm:MonitoredEnclosure hcm-bio:Subject ) ] ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( hcm-obs:BehaviorObservation hcm-obs:EnvironmentObservation hcm-obs:HealthStatusObservation hcm-obs:WeightObservation ) ] ;
    owl:inverseOf sosa:hasFeatureOfInterest .


