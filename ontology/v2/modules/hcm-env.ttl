# HCMO v2 (re-modularised draft, env) — env — environmental parameters (profiles, specs, properties)
# Generated for co-author review; see docs/paper/MODULE-MAP.md. Namespace policy: …/hcm/env#.
#
@prefix hcm-env: <https://w3id.org/hcmo/ontology/hcm/env#> .
@prefix hcm: <https://w3id.org/hcmo/ontology/hcm#> .
@prefix hcm-obs: <https://w3id.org/hcmo/ontology/hcm/obs#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

hcm-env:hasAmbientTemperature a owl:ObjectProperty ;
    rdfs:label "ambient temperature" ;
    rdfs:comment "Relates an environmental profile, specification, or observation to the environmental property representing ambient temperature." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-env:EnvironmentProfile hcm-env:MeasurementSpecification hcm-obs:EnvironmentObservation ) ] ;
    rdfs:range hcm-env:EnvironmentalProperty ;
    owl:inverseOf hcm-env:isAmbientTemperatureOf .

hcm-env:hasAmmoniaConcentration a owl:ObjectProperty ;
    rdfs:label "ammonia concentration" ;
    rdfs:comment "Relates an environmental profile, specification, or observation to the environmental property representing ammonia concentration." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-env:EnvironmentProfile hcm-env:MeasurementSpecification hcm-obs:EnvironmentObservation ) ] ;
    rdfs:range hcm-env:EnvironmentalProperty ;
    owl:inverseOf hcm-env:isAmmoniaConcentrationOf .

hcm-env:hasCarbonDioxideConcentration a owl:ObjectProperty ;
    rdfs:label "carbon dioxide concentration" ;
    rdfs:comment "Relates an environmental profile, specification, or observation to the environmental property representing carbon dioxide concentration." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-env:EnvironmentProfile hcm-env:MeasurementSpecification hcm-obs:EnvironmentObservation ) ] ;
    rdfs:range hcm-env:EnvironmentalProperty ;
    owl:inverseOf hcm-env:isCarbonDioxideConcentrationOf .

hcm-env:EnvironmentProfile a owl:Class ;
    rdfs:label "Environment Profile" ;
    rdfs:comment "A structured profile describing environmental conditions or requirements for a monitored enclosure." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom hcm-env:MeasurementSpecification ;
            owl:onProperty hcm-env:hasMeasurementSpec ],
        [ a owl:Restriction ;
            owl:allValuesFrom hcm-env:GasConcentrationProfile ;
            owl:onProperty hcm-env:hasGasConcentrationProfile ],
        [ a owl:Restriction ;
            owl:allValuesFrom hcm-env:LightCycle ;
            owl:onProperty hcm-env:hasLightCycle ] .

hcm-env:EnvironmentalProperty a owl:Class ;
    rdfs:label "Environmental Property" ;
    rdfs:comment "An environmental parameter that may be measured, specified, or controlled in a home-cage monitoring context." .

hcm-env:hasLightIntensity a owl:ObjectProperty ;
    rdfs:label "light intensity" ;
    rdfs:comment "Relates an environmental profile, specification, or observation to the environmental property representing light intensity." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-env:EnvironmentProfile hcm-env:MeasurementSpecification hcm-obs:EnvironmentObservation ) ] ;
    rdfs:range hcm-env:EnvironmentalProperty ;
    owl:inverseOf hcm-env:isLightIntensityOf .

hcm-env:hasLightState a owl:ObjectProperty ;
    rdfs:label "light state" ;
    rdfs:comment "Relates an environmental profile, specification, or observation to the environmental property representing light state." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-env:EnvironmentProfile hcm-env:MeasurementSpecification hcm-obs:EnvironmentObservation ) ] ;
    rdfs:range hcm-env:EnvironmentalProperty ;
    owl:inverseOf hcm-env:isLightStateOf .

hcm-env:hasOxygenConcentration a owl:ObjectProperty ;
    rdfs:label "oxygen concentration" ;
    rdfs:comment "Relates an environmental profile, specification, or observation to the environmental property representing oxygen concentration." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-env:EnvironmentProfile hcm-env:MeasurementSpecification hcm-obs:EnvironmentObservation ) ] ;
    rdfs:range hcm-env:EnvironmentalProperty ;
    owl:inverseOf hcm-env:isOxygenConcentrationOf .

hcm-env:hasRelativeHumidity a owl:ObjectProperty ;
    rdfs:label "relative humidity" ;
    rdfs:comment "Relates an environmental profile, specification, or observation to the environmental property representing relative humidity." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-env:EnvironmentProfile hcm-env:MeasurementSpecification hcm-obs:EnvironmentObservation ) ] ;
    rdfs:range hcm-env:EnvironmentalProperty ;
    owl:inverseOf hcm-env:isRelativeHumidityOf .

hcm-env:ThriveProfile a owl:Class ;
    rdfs:label "Thrive Profile" ;
    rdfs:comment "A welfare or husbandry profile describing environmental conditions intended to support animal thriving." .

hcm-env:hasEnvironment a owl:ObjectProperty ;
    rdfs:label "has environment" ;
    rdfs:comment "Relates an enclosure, observation, or study context to an environment profile or environmental context." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm:Enclosure hcm-obs:EnvironmentObservation ) ] ;
    rdfs:range hcm-env:EnvironmentProfile ;
    owl:inverseOf hcm-env:isEnvironmentOf .

hcm-env:hasDarkPhaseDuration a owl:DatatypeProperty ;
    rdfs:label "has dark phase duration" ;
    rdfs:comment "Records the duration of the dark phase in a light cycle." ;
    rdfs:domain hcm-env:LightCycle ;
    rdfs:range xsd:string .

hcm-env:hasDarkPhaseStart a owl:DatatypeProperty ;
    rdfs:label "has dark phase start" ;
    rdfs:comment "Records the start time of the dark phase in a light cycle." ;
    rdfs:domain hcm-env:LightCycle ;
    rdfs:range xsd:string .

hcm-env:hasDawnDuration a owl:DatatypeProperty ;
    rdfs:label "has dawn duration" ;
    rdfs:comment "Records the duration of the dawn transition in a light cycle." ;
    rdfs:domain hcm-env:LightCycle ;
    rdfs:range xsd:string .

hcm-env:hasDuskDuration a owl:DatatypeProperty ;
    rdfs:label "has dusk duration" ;
    rdfs:comment "Records the duration of the dusk transition in a light cycle." ;
    rdfs:domain hcm-env:LightCycle ;
    rdfs:range xsd:string .

hcm-env:hasGasType a owl:DatatypeProperty ;
    rdfs:label "has gas type" ;
    rdfs:comment "Records the gas type measured or specified in a gas concentration profile or observation." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm:MonitoredEnclosure hcm-env:GasConcentrationProfile hcm-obs:GasConcentrationObservation ) ] ;
    rdfs:range xsd:string .

hcm-env:hasLightPhaseDuration a owl:DatatypeProperty ;
    rdfs:label "has light phase duration" ;
    rdfs:comment "Records the duration of the light phase in a light cycle." ;
    rdfs:domain hcm-env:LightCycle ;
    rdfs:range xsd:string .

hcm-env:hasThriveProfile a owl:ObjectProperty ;
    rdfs:label "has thrive profile" ;
    rdfs:comment "Relates a monitored enclosure to the thrive profile that specifies suitable husbandry or environmental conditions." ;
    rdfs:domain hcm:MonitoredEnclosure ;
    rdfs:range hcm-env:ThriveProfile ;
    owl:inverseOf hcm-env:isThriveProfileOf .

hcm-env:hasValue a owl:DatatypeProperty ;
    rdfs:label "has value" ;
    rdfs:comment "Records a literal value for an environmental measurement or specification." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm:MonitoredEnclosure hcm-env:EnvironmentalProperty hcm-env:MeasurementSpecification hcm-obs:EnvironmentObservation ) ] ;
    rdfs:range xsd:string .

hcm-env:GasConcentrationProfile a owl:Class ;
    rdfs:label "Gas Concentration Profile" ;
    rdfs:comment "A profile describing concentrations of gases relevant to the monitored enclosure environment." .

hcm-env:LightCycle a owl:Class ;
    rdfs:label "Light Cycle" ;
    rdfs:comment "A description of the timing and transitions of light and dark phases in an enclosure environment." .

hcm-env:MeasurementSpecification a owl:Class ;
    rdfs:label "Measurement Specification" ;
    rdfs:comment "A specification describing how an environmental property is measured, represented, or constrained." .

hcm-env:hasGasConcentrationProfile a owl:ObjectProperty ;
    rdfs:label "has gas concentration profile" ;
    rdfs:comment "Relates an environment profile to a gas concentration profile." ;
    rdfs:domain hcm-env:EnvironmentProfile ;
    rdfs:range hcm-env:GasConcentrationProfile ;
    owl:inverseOf hcm-env:isGasConcentrationProfileOf .

hcm-env:hasLightCycle a owl:ObjectProperty ;
    rdfs:label "has light cycle" ;
    rdfs:comment "Relates an environment profile to a light cycle." ;
    rdfs:domain hcm-env:EnvironmentProfile ;
    rdfs:range hcm-env:LightCycle ;
    owl:inverseOf hcm-env:isLightCycleOf .

hcm-env:hasMeasurementSpec a owl:ObjectProperty ;
    rdfs:label "has measurement spec" ;
    rdfs:comment "Relates an environment profile to a measurement specification." ;
    rdfs:domain hcm-env:EnvironmentProfile ;
    rdfs:range hcm-env:MeasurementSpecification ;
    owl:inverseOf hcm-env:isMeasurementSpecOf .

hcm-env:isAmbientTemperatureOf a owl:ObjectProperty ;
    rdfs:label "is ambient temperature of" ;
    rdfs:comment "Inverse relation from an ambient-temperature environmental property to the profile, specification, or observation that uses it." ;
    rdfs:domain hcm-env:EnvironmentalProperty ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( hcm-env:EnvironmentProfile hcm-env:MeasurementSpecification hcm-obs:EnvironmentObservation ) ] ;
    owl:inverseOf hcm-env:hasAmbientTemperature .

hcm-env:isAmmoniaConcentrationOf a owl:ObjectProperty ;
    rdfs:label "is ammonia concentration of" ;
    rdfs:comment "Inverse relation from an ammonia-concentration environmental property to the profile, specification, or observation that uses it." ;
    rdfs:domain hcm-env:EnvironmentalProperty ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( hcm-env:EnvironmentProfile hcm-env:MeasurementSpecification hcm-obs:EnvironmentObservation ) ] ;
    owl:inverseOf hcm-env:hasAmmoniaConcentration .

hcm-env:isCarbonDioxideConcentrationOf a owl:ObjectProperty ;
    rdfs:label "is carbon dioxide concentration of" ;
    rdfs:comment "Inverse relation from a carbon-dioxide-concentration environmental property to the profile, specification, or observation that uses it." ;
    rdfs:domain hcm-env:EnvironmentalProperty ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( hcm-env:EnvironmentProfile hcm-env:MeasurementSpecification hcm-obs:EnvironmentObservation ) ] ;
    owl:inverseOf hcm-env:hasCarbonDioxideConcentration .

hcm-env:isEnvironmentOf a owl:ObjectProperty ;
    rdfs:label "is environment of" ;
    rdfs:comment "Inverse relation from an environment profile to the enclosure or observation context that uses it." ;
    rdfs:domain hcm-env:EnvironmentProfile ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( hcm:Enclosure hcm-obs:EnvironmentObservation ) ] ;
    owl:inverseOf hcm-env:hasEnvironment .

hcm-env:isGasConcentrationProfileOf a owl:ObjectProperty ;
    rdfs:label "is gas concentration profile of" ;
    rdfs:comment "Inverse relation from a gas concentration profile to its environment profile." ;
    rdfs:domain hcm-env:GasConcentrationProfile ;
    rdfs:range hcm-env:EnvironmentProfile ;
    owl:inverseOf hcm-env:hasGasConcentrationProfile .

hcm-env:isLightCycleOf a owl:ObjectProperty ;
    rdfs:label "is light cycle of" ;
    rdfs:comment "Inverse relation from a light cycle to its environment profile." ;
    rdfs:domain hcm-env:LightCycle ;
    rdfs:range hcm-env:EnvironmentProfile ;
    owl:inverseOf hcm-env:hasLightCycle .

hcm-env:isLightIntensityOf a owl:ObjectProperty ;
    rdfs:label "is light intensity of" ;
    rdfs:comment "Inverse relation from a light-intensity environmental property to the profile, specification, or observation that uses it." ;
    rdfs:domain hcm-env:EnvironmentalProperty ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( hcm-env:EnvironmentProfile hcm-env:MeasurementSpecification hcm-obs:EnvironmentObservation ) ] ;
    owl:inverseOf hcm-env:hasLightIntensity .

hcm-env:isLightStateOf a owl:ObjectProperty ;
    rdfs:label "is light state of" ;
    rdfs:comment "Inverse relation from a light-state environmental property to the profile, specification, or observation that uses it." ;
    rdfs:domain hcm-env:EnvironmentalProperty ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( hcm-env:EnvironmentProfile hcm-env:MeasurementSpecification hcm-obs:EnvironmentObservation ) ] ;
    owl:inverseOf hcm-env:hasLightState .

hcm-env:isMeasurementSpecOf a owl:ObjectProperty ;
    rdfs:label "is measurement spec of" ;
    rdfs:comment "Inverse relation from a measurement specification to its environment profile." ;
    rdfs:domain hcm-env:MeasurementSpecification ;
    rdfs:range hcm-env:EnvironmentProfile ;
    owl:inverseOf hcm-env:hasMeasurementSpec .

hcm-env:isOxygenConcentrationOf a owl:ObjectProperty ;
    rdfs:label "is oxygen concentration of" ;
    rdfs:comment "Inverse relation from an oxygen-concentration environmental property to the profile, specification, or observation that uses it." ;
    rdfs:domain hcm-env:EnvironmentalProperty ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( hcm-env:EnvironmentProfile hcm-env:MeasurementSpecification hcm-obs:EnvironmentObservation ) ] ;
    owl:inverseOf hcm-env:hasOxygenConcentration .

hcm-env:isRelativeHumidityOf a owl:ObjectProperty ;
    rdfs:label "is relative humidity of" ;
    rdfs:comment "Inverse relation from a relative-humidity environmental property to the profile, specification, or observation that uses it." ;
    rdfs:domain hcm-env:EnvironmentalProperty ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( hcm-env:EnvironmentProfile hcm-env:MeasurementSpecification hcm-obs:EnvironmentObservation ) ] ;
    owl:inverseOf hcm-env:hasRelativeHumidity .

hcm-env:isThriveProfileOf a owl:ObjectProperty ;
    rdfs:label "is thrive profile of" ;
    rdfs:comment "Inverse relation from a thrive profile to the monitored enclosure that uses it." ;
    rdfs:domain hcm-env:ThriveProfile ;
    rdfs:range hcm:MonitoredEnclosure ;
    owl:inverseOf hcm-env:hasThriveProfile .

