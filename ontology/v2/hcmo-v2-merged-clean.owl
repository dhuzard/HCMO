              <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm/obs#EnvironmentObservation"/>
              <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm/obs#ObservationResult"/>
            </owl:unionOf>
          </owl:Class>
        </rdfs:domain>
        <rdfs:label>has dimension</rdfs:label>
        <rdfs:range rdf:resource="https://w3id.org/semts/ontology/120#DataDimension"/>
        <owl:inverseOf rdf:resource="https://w3id.org/semts/ontology/120#isDimensionOf"/>
      </owl:ObjectProperty>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:Class rdf:about="https://w3id.org/semts/ontology/120#DataDimension">
    <rdfs:comment>SEMTS class used for dimensions of time-series or tabular data generated by an HCMO observation.</rdfs:comment>
    <rdfs:label>Data Dimension</rdfs:label>
  </owl:Class>
  <owl:ObjectProperty rdf:about="https://w3id.org/hcmo/ontology/hcm/tech#runsSoftware">
    <rdfs:comment>Inverse relation from hardware to software that runs on it.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/hcmo/ontology/hcm/tech#Hardware"/>
    <rdfs:label>runs software</rdfs:label>
    <rdfs:range rdf:resource="https://w3id.org/hcmo/ontology/hcm/tech#Software"/>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="https://w3id.org/hcmo/ontology/hcm/tech#runsOn">
        <rdfs:comment>Relates software to the hardware or platform on which it executes.</rdfs:comment>
        <rdfs:domain rdf:resource="https://w3id.org/hcmo/ontology/hcm/tech#Software"/>
        <rdfs:label>runs on</rdfs:label>
        <rdfs:range rdf:resource="https://w3id.org/hcmo/ontology/hcm/tech#Hardware"/>
        <owl:inverseOf rdf:resource="https://w3id.org/hcmo/ontology/hcm/tech#runsSoftware"/>
      </owl:ObjectProperty>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:Class rdf:about="https://w3id.org/hcmo/ontology/hcm/bio#HousingAssignment">
    <rdfs:comment>A record assigning a subject or group to an enclosure in a study or housing context.</rdfs:comment>
