          <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm/obs#ObservationResult"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:label>has interval</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:Class rdf:about="https://w3id.org/hcmo/ontology/hcm#Location">
    <rdfs:comment>A facility, room, rack, or other physical location in which an enclosure or monitored enclosure is situated.</rdfs:comment>
    <rdfs:label>Location</rdfs:label>
  </owl:Class>
  <owl:DatatypeProperty rdf:about="https://w3id.org/hcmo/ontology/hcm/obs#hasConfidenceScore">
