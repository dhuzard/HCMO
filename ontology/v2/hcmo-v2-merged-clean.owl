      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction rdf:nodeID="cb223541e6c8837b0bc004de83d581e98eec444b1ca17686e81c542e48a9f548b5a">
        <owl:onProperty rdf:resource="http://www.w3.org/ns/sosa/hasResult"/>
        <owl:someValuesFrom rdf:resource="https://w3id.org/hcmo/ontology/hcm/obs#BehaviorResult"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/hcmo/ontology/hcm/obs#ObservationCondition">
    <rdfs:comment>A condition, state, or contextual qualifier under which an observation was made or interpreted.</rdfs:comment>
    <rdfs:label>Observation Condition</rdfs:label>
  </owl:Class>
  <owl:ObjectProperty rdf:about="http://www.w3.org/ns/sosa/observedProperty">
    <rdfs:comment>SOSA relation linking an observation to the property being observed.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/hcmo/ontology/hcm/obs#ObservationContext"/>
    <rdfs:label>observed property</rdfs:label>
    <rdfs:range rdf:resource="https://w3id.org/hcmo/ontology/hcm/obs#ObservableProperty"/>
