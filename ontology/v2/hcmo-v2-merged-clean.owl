      <owl:Restriction rdf:nodeID="cb1d08c559ba497ad59c67752997aa5dff00af19a964f826017caf6cd06a9584999">
        <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
        <owl:onProperty rdf:resource="https://w3id.org/hcmo/ontology/hcm/bio#hasTreatment"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/hcmo/ontology/hcm#EnclosureDimensions">
    <rdfs:comment>A dimensions record describing the physical size of an enclosure.</rdfs:comment>
    <rdfs:label>Enclosure Dimensions</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/hcmo/ontology/hcm/bio#SubjectObservationBearer">
