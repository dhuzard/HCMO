      <owl:Restriction rdf:nodeID="cb321564c1ffdcae248eb14b60f7e3756b7d0593ef266ee54081f3d6bf9adb9c7ad">
        <owl:onProperty rdf:resource="https://w3id.org/hcmo/ontology/hcm/tech#supportsEnclosure"/>
        <owl:someValuesFrom rdf:resource="https://w3id.org/hcmo/ontology/hcm#MonitoredEnclosure"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <owl:disjointWith rdf:resource="https://w3id.org/hcmo/ontology/hcm/tech#Software"/>
  </owl:Class>
  <owl:DatatypeProperty rdf:about="https://w3id.org/hcmo/ontology/hcm#hasEnclosureIdentifier">
    <rdfs:comment>Records the identifier assigned to an enclosure or monitored enclosure.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/hcmo/ontology/hcm#Enclosure"/>
    <rdfs:label>has enclosure identifier</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:ObjectProperty rdf:about="https://w3id.org/semts/ontology/120#isDimensionOf">
    <rdfs:comment>Inverse relation from a data dimension to the observation or result that uses it.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/semts/ontology/120#DataDimension"/>
    <rdfs:label>is dimension of</rdfs:label>
    <rdfs:range>
      <owl:Class rdf:nodeID="cb14e38fa8a2dde64748f237f11e09c378ec967bfee496663ca73f3a54a741784b7">
