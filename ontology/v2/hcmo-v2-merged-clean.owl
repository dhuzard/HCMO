  </owl:DatatypeProperty>
  <owl:Class rdf:about="https://w3id.org/hcmo/ontology/hcm/bio#StudyFactors">
    <rdfs:comment>A collection of experimental or husbandry factors that may affect subjects, housing, or observations.</rdfs:comment>
    <rdfs:label>Study Factors</rdfs:label>
