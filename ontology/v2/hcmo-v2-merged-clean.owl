    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction rdf:nodeID="cb37966b5341a8908d54b4796ca6b8cd0639ce85a692e985eeecdac19303f7cfa64">
        <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
