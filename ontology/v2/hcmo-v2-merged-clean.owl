      <owl:Class rdf:nodeID="cb192fcc563f007229a9a01737d05238d5b6aca104ff90d0a67908ee9ed2744a045">
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm#MonitoredEnclosure"/>
