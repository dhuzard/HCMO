        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:label>has beginning</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#isBeginningOf">
        <rdfs:comment>Inverse relation from a beginning temporal entity to the interval or monitoring context it begins.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
        <rdfs:label>is beginning of</rdfs:label>
        <rdfs:range>
          <owl:Class rdf:nodeID="cb147372d0a4fa74515987c416a768ce130333ec24b62e8ea36c0a37f3c8e1b663b">
            <owl:unionOf rdf:parseType="Collection">
              <rdf:Description rdf:about="http://www.w3.org/2006/time#TemporalEntity"/>
