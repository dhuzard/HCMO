      <owl:Restriction rdf:nodeID="cb2625d47294f6f94d6512d3fe7e510c07ba3cde7a9d62cefe10dc92e974450a548">
        <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxCardinality>
        <owl:onProperty rdf:resource="http://www.w3.org/ns/sosa/usedProcedure"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf>
      <owl:Restriction rdf:nodeID="cb2744715a5674a8723c3581b657b57be0585e966b99b6d281ff2fa940935400cd3">
        <owl:onProperty rdf:resource="http://www.w3.org/ns/sosa/hasFeatureOfInterest"/>
