              <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm/obs#ObservationResult"/>
            </owl:unionOf>
          </owl:Class>
        </rdfs:range>
        <owl:inverseOf rdf:resource="http://www.w3.org/2006/time#hasBeginning"/>
      </owl:ObjectProperty>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:DatatypeProperty rdf:about="https://w3id.org/hcmo/ontology/hcm/env#hasValue">
    <rdfs:comment>Records a literal value for an environmental measurement or specification.</rdfs:comment>
