        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm/env#EnvironmentProfile"/>
          <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm/env#MeasurementSpecification"/>
          <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm/obs#EnvironmentObservation"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:range>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="https://w3id.org/hcmo/ontology/hcm/env#hasRelativeHumidity">
        <rdfs:comment>Relates an environmental profile, specification, or observation to the environmental property representing relative humidity.</rdfs:comment>
        <rdfs:domain>
          <owl:Class rdf:nodeID="cbff4f13c18c18eb82ed0b4e6cfac9f6950e5d4c8ac4649a1d695a893b92307cbe">
            <owl:unionOf rdf:parseType="Collection">
              <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm/env#EnvironmentProfile"/>
              <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm/env#MeasurementSpecification"/>
              <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm/obs#EnvironmentObservation"/>
            </owl:unionOf>
          </owl:Class>
        </rdfs:domain>
        <rdfs:label>relative humidity</rdfs:label>
        <rdfs:range rdf:resource="https://w3id.org/hcmo/ontology/hcm/env#EnvironmentalProperty"/>
        <owl:inverseOf rdf:resource="https://w3id.org/hcmo/ontology/hcm/env#isRelativeHumidityOf"/>
      </owl:ObjectProperty>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://w3id.org/hcmo/ontology/hcm/tech#monitors">
    <rdfs:comment>Inverse relation from a sensor to the enclosure or observation result that it monitors.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/hcmo/ontology/hcm/tech#Sensor"/>
    <rdfs:label>monitors</rdfs:label>
    <rdfs:range>
      <owl:Class rdf:nodeID="cbdaeffa616ff607d340ea9dd686de3165c7dfdf4177a58400ba530359126a93c3">
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm#MonitoredEnclosure"/>
          <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm/obs#ObservationResult"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:range>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="https://w3id.org/hcmo/ontology/hcm/tech#monitoredBy">
        <rdfs:comment>Relates a monitored enclosure, subject, process, or property to the sensor or monitoring component observing it.</rdfs:comment>
        <rdfs:domain>
          <owl:Class rdf:nodeID="cb1bc1cfda4e8d91b1db00a4eb6e30b5b659832de1e6f125887b725bee525087562">
            <owl:unionOf rdf:parseType="Collection">
              <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm#MonitoredEnclosure"/>
              <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm/obs#ObservationResult"/>
            </owl:unionOf>
          </owl:Class>
        </rdfs:domain>
        <rdfs:label>monitored by</rdfs:label>
        <rdfs:range rdf:resource="https://w3id.org/hcmo/ontology/hcm/tech#Sensor"/>
        <owl:inverseOf rdf:resource="https://w3id.org/hcmo/ontology/hcm/tech#monitors"/>
      </owl:ObjectProperty>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:Class rdf:about="https://w3id.org/hcmo/ontology/hcm/obs#BehaviorObservation">
    <rdfs:comment>A SOSA-style observation about the behavior of a subject in a home-cage monitoring context.</rdfs:comment>
    <rdfs:label>Behavior Observation</rdfs:label>
