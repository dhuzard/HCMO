  <owl:Class rdf:about="https://w3id.org/hcmo/ontology/hcm/env#EnvironmentProfile">
    <rdfs:comment>A structured profile describing environmental conditions or requirements for a monitored enclosure.</rdfs:comment>
    <rdfs:label>Environment Profile</rdfs:label>
    <rdfs:subClassOf>
      <owl:Restriction rdf:nodeID="cb16ecbbc8bf4babbcae00a50aaf1e70557b2dd74f57693930fbe651ab1ed75e499">
