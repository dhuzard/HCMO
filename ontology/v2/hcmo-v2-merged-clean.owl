      <owl:Restriction rdf:nodeID="cb218c99c91cf3e0b0a8925ac09fea216aa607246eb25cd992b4aa36ee74c89203c">
        <owl:onProperty rdf:resource="http://www.w3.org/ns/sosa/hasFeatureOfInterest"/>
