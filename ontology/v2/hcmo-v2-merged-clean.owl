              <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm/bio#ExperimentalGroup"/>
            </owl:unionOf>
          </owl:Class>
        </rdfs:domain>
        <rdfs:label>has housing assignment</rdfs:label>
        <rdfs:range rdf:resource="https://w3id.org/hcmo/ontology/hcm/bio#HousingAssignment"/>
