      <owl:ObjectProperty rdf:about="https://w3id.org/hcmo/ontology/hcm/obs#isObservedPropertyOf">
        <rdfs:comment>Inverse relation from an observed property to the observation that observes it.</rdfs:comment>
        <rdfs:domain rdf:resource="https://w3id.org/hcmo/ontology/hcm/obs#ObservableProperty"/>
        <rdfs:label>is observed property of</rdfs:label>
        <rdfs:range rdf:resource="https://w3id.org/hcmo/ontology/hcm/obs#ObservationContext"/>
        <owl:inverseOf rdf:resource="http://www.w3.org/ns/sosa/observedProperty"/>
      </owl:ObjectProperty>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:Class rdf:about="https://w3id.org/hcmo/ontology/hcm/tech#Hardware">
    <rdfs:comment>Physical computing hardware component of a home-cage monitoring system.</rdfs:comment>
    <rdfs:label>Hardware</rdfs:label>
