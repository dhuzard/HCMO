    <rdfs:label>is monitored animal in</rdfs:label>
    <rdfs:range rdf:resource="https://w3id.org/hcmo/ontology/hcm#MonitoredEnclosure"/>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="https://w3id.org/hcmo/ontology/hcm#hasMonitoredAnimals">
        <rdfs:comment>Relates a monitored enclosure to the biological subjects housed or tracked within it.</rdfs:comment>
        <rdfs:domain rdf:resource="https://w3id.org/hcmo/ontology/hcm#MonitoredEnclosure"/>
        <rdfs:label>has monitored animals</rdfs:label>
        <rdfs:range rdf:resource="https://w3id.org/hcmo/ontology/hcm/bio#Subject"/>
        <owl:inverseOf rdf:resource="https://w3id.org/hcmo/ontology/hcm#isMonitoredAnimalIn"/>
      </owl:ObjectProperty>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://w3id.org/hcmo/ontology/hcm/bio#hasMember">
    <rdfs:comment>Relates an experimental group to a subject that is a member of the group.</rdfs:comment>
