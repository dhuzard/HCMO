    <rdfs:label>has health status term</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:ObjectProperty rdf:about="https://w3id.org/hcmo/ontology/hcm/bio#isWeightObservationOf">
    <rdfs:comment>Inverse relation from a weight observation to the subject it observes.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/hcmo/ontology/hcm/obs#WeightObservation"/>
    <rdfs:label>is weight observation of</rdfs:label>
    <rdfs:range rdf:resource="https://w3id.org/hcmo/ontology/hcm/bio#SubjectObservationBearer"/>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="https://w3id.org/hcmo/ontology/hcm/bio#hasWeightObservation">
        <rdfs:comment>Relates a subject to a weight observation about that subject.</rdfs:comment>
        <rdfs:domain rdf:resource="https://w3id.org/hcmo/ontology/hcm/bio#SubjectObservationBearer"/>
        <rdfs:label>has weight observation</rdfs:label>
        <rdfs:range rdf:resource="https://w3id.org/hcmo/ontology/hcm/obs#WeightObservation"/>
        <owl:inverseOf rdf:resource="https://w3id.org/hcmo/ontology/hcm/bio#isWeightObservationOf"/>
      </owl:ObjectProperty>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://w3id.org/semts/ontology/120#during">
    <rdfs:comment>SEMTS relation linking a data segment to the temporal entity during which it occurs.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/semts/ontology/120#TimeSeriesSegment"/>
    <rdfs:label>during</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="https://w3id.org/semts/ontology/120#hasTimeSeriesSegment">
        <rdfs:comment>Inverse relation from a temporal entity to a time-series segment that occurs during it.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
        <rdfs:label>has time series segment</rdfs:label>
        <rdfs:range rdf:resource="https://w3id.org/semts/ontology/120#TimeSeriesSegment"/>
        <owl:inverseOf rdf:resource="https://w3id.org/semts/ontology/120#during"/>
      </owl:ObjectProperty>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://w3id.org/hcmo/ontology/hcm/env#isRelativeHumidityOf">
    <rdfs:comment>Inverse relation from a relative-humidity environmental property to the profile, specification, or observation that uses it.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/hcmo/ontology/hcm/env#EnvironmentalProperty"/>
    <rdfs:label>is relative humidity of</rdfs:label>
