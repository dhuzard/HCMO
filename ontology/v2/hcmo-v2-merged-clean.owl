      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:subClassOf rdf:resource="https://w3id.org/hcmo/ontology/hcm/obs#ObservationResult"/>
  </owl:Class>
  <owl:DatatypeProperty rdf:about="https://w3id.org/hcmo/ontology/hcm#hasLength">
