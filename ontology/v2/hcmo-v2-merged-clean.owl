          </owl:Class>
        </rdfs:range>
        <owl:inverseOf rdf:resource="https://w3id.org/hcmo/ontology/hcm/tech#installedIn"/>
      </owl:ObjectProperty>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://w3id.org/hcmo/ontology/hcm/obs#occursIn">
    <rdfs:comment>Relates an observation, result, or event to the enclosure or context in which it occurs.</rdfs:comment>
