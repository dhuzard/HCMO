          <owl:Class rdf:nodeID="cb1fc61f8e2b8e86fe79291c47d5d5de5e34a61e72bcc84d99eeb01b84e0fb381bb">
            <owl:unionOf rdf:parseType="Collection">
              <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm#MonitoredEnclosure"/>
              <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm/tech#Hardware"/>
              <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm/tech#Sensor"/>
            </owl:unionOf>
          </owl:Class>
        </rdfs:domain>
        <rdfs:label>has actuator</rdfs:label>
        <rdfs:range rdf:resource="https://w3id.org/hcmo/ontology/hcm/tech#Actuator"/>
        <owl:inverseOf rdf:resource="https://w3id.org/hcmo/ontology/hcm/tech#isActuatorOf"/>
      </owl:ObjectProperty>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:DatatypeProperty rdf:about="https://w3id.org/hcmo/ontology/hcm#isOccupied">
    <rdfs:comment>Indicates whether an enclosure is currently occupied by animals.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/hcmo/ontology/hcm#MonitoredEnclosure"/>
    <rdfs:label>is occupied</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>
  <owl:ObjectProperty rdf:about="https://w3id.org/hcmo/ontology/hcm/env#isGasConcentrationProfileOf">
    <rdfs:comment>Inverse relation from a gas concentration profile to its environment profile.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/hcmo/ontology/hcm/env#GasConcentrationProfile"/>
    <rdfs:label>is gas concentration profile of</rdfs:label>
    <rdfs:range rdf:resource="https://w3id.org/hcmo/ontology/hcm/env#EnvironmentProfile"/>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="https://w3id.org/hcmo/ontology/hcm/env#hasGasConcentrationProfile">
        <rdfs:comment>Relates an environment profile to a gas concentration profile.</rdfs:comment>
        <rdfs:domain rdf:resource="https://w3id.org/hcmo/ontology/hcm/env#EnvironmentProfile"/>
        <rdfs:label>has gas concentration profile</rdfs:label>
        <rdfs:range rdf:resource="https://w3id.org/hcmo/ontology/hcm/env#GasConcentrationProfile"/>
        <owl:inverseOf rdf:resource="https://w3id.org/hcmo/ontology/hcm/env#isGasConcentrationProfileOf"/>
      </owl:ObjectProperty>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://w3id.org/hcmo/ontology/hcm/bio#hasBehaviorObservation">
    <rdfs:comment>Relates a subject to a behavior observation about that subject.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/hcmo/ontology/hcm/bio#SubjectObservationBearer"/>
    <rdfs:label>has behavior observation</rdfs:label>
    <rdfs:range rdf:resource="https://w3id.org/hcmo/ontology/hcm/obs#BehaviorObservation"/>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="https://w3id.org/hcmo/ontology/hcm/bio#isBehaviorObservationOf">
        <rdfs:comment>Inverse relation from a behavior observation to the subject it observes.</rdfs:comment>
        <rdfs:domain rdf:resource="https://w3id.org/hcmo/ontology/hcm/obs#BehaviorObservation"/>
        <rdfs:label>is behavior observation of</rdfs:label>
        <rdfs:range rdf:resource="https://w3id.org/hcmo/ontology/hcm/bio#SubjectObservationBearer"/>
        <owl:inverseOf rdf:resource="https://w3id.org/hcmo/ontology/hcm/bio#hasBehaviorObservation"/>
      </owl:ObjectProperty>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:Class rdf:about="https://w3id.org/hcmo/ontology/hcm/obs#CategoricalResult">
    <rdfs:comment>An observation result represented by a category rather than a numeric value.</rdfs:comment>
    <rdfs:label>Categorical Result</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/hcmo/ontology/hcm/obs#ObservationResult"/>
  </owl:Class>
  <owl:ObjectProperty rdf:about="https://w3id.org/hcmo/ontology/hcm#isMonitoredAnimalIn">
    <rdfs:comment>Inverse relation from a biological subject to the monitored enclosure in which it is housed or tracked.</rdfs:comment>
