        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm/bio#Subject"/>
          <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm#MonitoredEnclosure"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:label>has species</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:Class rdf:about="https://w3id.org/hcmo/ontology/hcm/obs#ObservationContext">
    <rdfs:comment>An observation-like context, including observations, results, or monitored-enclosure contexts that currently carry observation restrictions in the v2 draft.</rdfs:comment>
    <rdfs:label>Observation Context</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/hcmo/ontology/hcm/obs#HealthStatusObservation">
    <rdfs:comment>A SOSA-style observation about the health status of a biological subject.</rdfs:comment>
    <rdfs:label>Health Status Observation</rdfs:label>
    <rdfs:subClassOf>
      <owl:Restriction rdf:nodeID="cb1cb06e96e9caf6ed3eb5396f63ba5beca267e783a500e2618cb5a7d826093bc01">
        <owl:onProperty rdf:resource="http://www.w3.org/ns/sosa/hasFeatureOfInterest"/>
        <owl:someValuesFrom rdf:resource="https://w3id.org/hcmo/ontology/hcm/bio#Subject"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/hcmo/ontology/hcm/env#LightCycle">
    <rdfs:comment>A description of the timing and transitions of light and dark phases in an enclosure environment.</rdfs:comment>
    <rdfs:label>Light Cycle</rdfs:label>
  </owl:Class>
  <owl:DatatypeProperty rdf:about="https://w3id.org/hcmo/ontology/hcm/obs#hasNumericValue">
    <rdfs:comment>Records the numeric value of a quantity result or measurement.</rdfs:comment>
    <rdfs:domain>
      <owl:Class rdf:nodeID="cbce6348d7642edfb2e713093f8bb826944566cec66618dc6dc4e258c1696f4bb3">
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm#MonitoredEnclosure"/>
          <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm/obs#QuantityValue"/>
          <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm/obs#ObservationResult"/>
          <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm/obs#EnvironmentObservation"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
    <rdfs:label>has numeric value</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>
  <owl:Class rdf:about="https://w3id.org/hcmo/ontology/hcm/obs#ObservableProperty">
    <rdfs:comment>A property, result, or parameter that can be used as the observed property of an HCMO observation.</rdfs:comment>
    <rdfs:label>Observable Property</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/hcmo/ontology/hcm/tech#TimeSeries">
    <rdfs:comment>An ordered sequence of time-indexed measurements or outputs produced in a monitoring workflow.</rdfs:comment>
    <rdfs:label>Time Series</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/hcmo/ontology/hcm/obs#ObservationResult"/>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/hcmo/ontology/hcm#Enrichment">
    <rdfs:comment>A material, structure, or intervention provided within an enclosure to support animal welfare or experimental conditions.</rdfs:comment>
    <rdfs:label>Enrichment</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/hcmo/ontology/hcm/bio#ExperimentalGroup">
    <rdfs:comment>A group of biological subjects sharing an experimental condition, treatment, or study role.</rdfs:comment>
    <rdfs:label>Experimental Group</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/hcmo/ontology/hcm/obs#BehaviorResult">
    <rdfs:comment>An observation result representing a detected, classified, or recorded behavior.</rdfs:comment>
    <rdfs:label>Behavior Result</rdfs:label>
  </owl:Class>
</rdf:RDF>
