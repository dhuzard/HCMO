        </owl:unionOf>
      </owl:Class>
    </rdfs:range>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="https://w3id.org/semts/ontology/120#hasDimension">
        <rdfs:comment>SEMTS relation linking a data artifact or observation to one of its data dimensions.</rdfs:comment>
