          <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm/tech#Sensor"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:range>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="https://w3id.org/hcmo/ontology/hcm/tech#hasActuator">
        <rdfs:comment>Relates a monitoring setup or technical component to an actuator associated with it.</rdfs:comment>
