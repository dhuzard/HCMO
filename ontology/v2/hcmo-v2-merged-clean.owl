      </owl:Class>
    </rdfs:domain>
    <rdfs:label>has value</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:Class rdf:about="https://w3id.org/hcmo/ontology/hcm/tech#Actuator">
    <rdfs:comment>A device that elicits or perturbs behavior, physiology, or the monitored environment.</rdfs:comment>
    <rdfs:label>Actuator</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/hcmo/ontology/hcm/tech#Sensor">
    <rdfs:comment>A device that captures signals related to behavior, physiology, or enclosure environment.</rdfs:comment>
    <rdfs:label>Sensor</rdfs:label>
    <rdfs:subClassOf>
      <owl:Restriction rdf:nodeID="cb2c85423b11c3882a7b16642ff1e482506431b0d742ab1502a033f5ed64335a7eb">
        <owl:onProperty rdf:resource="https://w3id.org/hcmo/ontology/hcm/tech#installedIn"/>
        <owl:someValuesFrom rdf:resource="https://w3id.org/hcmo/ontology/hcm#MonitoredEnclosure"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <owl:disjointWith rdf:resource="https://w3id.org/hcmo/ontology/hcm/tech#Actuator"/>
  </owl:Class>
  <owl:Class rdf:about="https://w3id.org/hcmo/ontology/hcm/tech#Software">
    <rdfs:comment>Software component used to acquire, process, store, or analyse home-cage monitoring data.</rdfs:comment>
    <rdfs:label>Software</rdfs:label>
    <rdfs:subClassOf>
      <owl:Restriction rdf:nodeID="cb2440e8df82cf2507be936c64d9657556f9d1ea332cfe2b4cb43cf8ea5933251d3">
        <owl:onProperty rdf:resource="https://w3id.org/hcmo/ontology/hcm/tech#runsOn"/>
        <owl:someValuesFrom rdf:resource="https://w3id.org/hcmo/ontology/hcm/tech#Hardware"/>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:ObjectProperty rdf:about="https://w3id.org/hcmo/ontology/hcm/env#isLightIntensityOf">
    <rdfs:comment>Inverse relation from a light-intensity environmental property to the profile, specification, or observation that uses it.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/hcmo/ontology/hcm/env#EnvironmentalProperty"/>
    <rdfs:label>is light intensity of</rdfs:label>
    <rdfs:range>
      <owl:Class rdf:nodeID="cb148112725248f6ba0840cd88f5ca3c8127695495f40fcc83eae3ea34c0376f619">
        <owl:unionOf rdf:parseType="Collection">
          <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm/env#EnvironmentProfile"/>
          <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm/env#MeasurementSpecification"/>
          <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm/obs#EnvironmentObservation"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:range>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="https://w3id.org/hcmo/ontology/hcm/env#hasLightIntensity">
        <rdfs:comment>Relates an environmental profile, specification, or observation to the environmental property representing light intensity.</rdfs:comment>
        <rdfs:domain>
          <owl:Class rdf:nodeID="cb13e8e7d1508d41fc1dd4071e875711d47d32a3bb9e12dbbeb7812147c3bdf5c88">
            <owl:unionOf rdf:parseType="Collection">
              <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm/env#EnvironmentProfile"/>
              <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm/env#MeasurementSpecification"/>
              <rdf:Description rdf:about="https://w3id.org/hcmo/ontology/hcm/obs#EnvironmentObservation"/>
            </owl:unionOf>
          </owl:Class>
        </rdfs:domain>
        <rdfs:label>light intensity</rdfs:label>
        <rdfs:range rdf:resource="https://w3id.org/hcmo/ontology/hcm/env#EnvironmentalProperty"/>
        <owl:inverseOf rdf:resource="https://w3id.org/hcmo/ontology/hcm/env#isLightIntensityOf"/>
      </owl:ObjectProperty>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="http://www.w3.org/ns/sosa/phenomenonTime">
    <rdfs:comment>SOSA relation linking an observation to the time that the observed phenomenon occurred.</rdfs:comment>
    <rdfs:domain rdf:resource="https://w3id.org/hcmo/ontology/hcm/obs#ObservationContext"/>
    <rdfs:label>phenomenon time</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="https://w3id.org/hcmo/ontology/hcm/obs#isPhenomenonTimeOf">
        <rdfs:comment>Inverse relation from a temporal entity to the observation or result whose phenomenon time it is.</rdfs:comment>
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#TemporalEntity"/>
        <rdfs:label>is phenomenon time of</rdfs:label>
        <rdfs:range rdf:resource="https://w3id.org/hcmo/ontology/hcm/obs#ObservationContext"/>
        <owl:inverseOf rdf:resource="http://www.w3.org/ns/sosa/phenomenonTime"/>
      </owl:ObjectProperty>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:Class rdf:about="https://w3id.org/hcmo/ontology/hcm/obs#WeightObservation">
    <rdfs:comment>A SOSA-style observation reporting the body weight of a biological subject.</rdfs:comment>
