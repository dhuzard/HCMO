      <owl:ObjectProperty rdf:about="https://w3id.org/hcmo/ontology/hcm/obs#hasOccurrence">
        <rdfs:comment>Inverse relation from a monitored enclosure to an observation, result, or event that occurs in it.</rdfs:comment>
        <rdfs:domain rdf:resource="https://w3id.org/hcmo/ontology/hcm#MonitoredEnclosure"/>
        <rdfs:label>has occurrence</rdfs:label>
