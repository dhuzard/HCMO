      </owl:Class>
    </rdfs:domain>
    <rdfs:label>has length</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>
  <owl:Class rdf:about="https://w3id.org/hcmo/ontology/hcm/env#EnvironmentalProperty">
    <rdfs:comment>An environmental parameter that may be measured, specified, or controlled in a home-cage monitoring context.</rdfs:comment>
    <rdfs:label>Environmental Property</rdfs:label>
  </owl:Class>
