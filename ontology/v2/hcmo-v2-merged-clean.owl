    <rdfs:label>has member</rdfs:label>
    <rdfs:range rdf:resource="https://w3id.org/hcmo/ontology/hcm/bio#Subject"/>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="https://w3id.org/hcmo/ontology/hcm/bio#isMemberOf">
        <rdfs:comment>Inverse relation from a subject to an experimental group in which it is a member.</rdfs:comment>
        <rdfs:domain rdf:resource="https://w3id.org/hcmo/ontology/hcm/bio#Subject"/>
        <rdfs:label>is member of</rdfs:label>
        <rdfs:range rdf:resource="https://w3id.org/hcmo/ontology/hcm/bio#ExperimentalGroup"/>
        <owl:inverseOf rdf:resource="https://w3id.org/hcmo/ontology/hcm/bio#hasMember"/>
      </owl:ObjectProperty>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://w3id.org/hcmo/ontology/hcm/tech#installedIn">
    <rdfs:comment>Relates a sensor or technical component to the monitored enclosure or setup in which it is installed.</rdfs:comment>
