    rdfs:label "belongs to group" ;
    rdfs:comment "Relates a subject, assignment, or monitored enclosure context to an experimental group." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-bio:Subject hcm-bio:HousingAssignment hcm:MonitoredEnclosure ) ] ;
    rdfs:range hcm-bio:ExperimentalGroup .

hcm-bio:hasBehaviorObservation a owl:ObjectProperty ;
    rdfs:label "has behavior observation" ;
    rdfs:comment "Relates a subject to a behavior observation about that subject." ;
    rdfs:range hcm-obs:BehaviorObservation .

hcm-bio:hasBiologicalSex a owl:DatatypeProperty ;
    rdfs:label "has biological sex" ;
    rdfs:comment "Records the biological sex reported for a subject." ;
    rdfs:range xsd:string .

hcm-bio:hasDateOfBirth a owl:DatatypeProperty ;
    rdfs:label "has date of birth" ;
    rdfs:comment "Records the date of birth reported for a subject." ;
    rdfs:range xsd:string .

hcm-bio:hasHealthStatusObservation a owl:ObjectProperty ;
    rdfs:label "has health status observation" ;
    rdfs:comment "Relates a subject to a health-status observation about that subject." ;
    rdfs:range hcm-obs:HealthStatusObservation .

hcm-bio:hasSpecies a owl:DatatypeProperty ;
    rdfs:label "has species" ;
    rdfs:comment "Records the species name or identifier reported for a subject." ;
    rdfs:range xsd:string .

hcm-bio:hasStrain a owl:DatatypeProperty ;
    rdfs:label "has strain" ;
    rdfs:comment "Records the strain, line, or breed reported for a subject." ;
    rdfs:range xsd:string .

hcm-bio:hasTreatment a owl:DatatypeProperty ;
    rdfs:label "has treatment" ;
    rdfs:comment "Records a treatment, intervention, or experimental condition assigned to a subject or group." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-bio:Subject hcm-bio:ExperimentalGroup hcm-bio:StudyFactors ) ] ;
    rdfs:range xsd:string .

hcm-bio:hasWeightObservation a owl:ObjectProperty ;
    rdfs:label "has weight observation" ;
    rdfs:comment "Relates a subject to a weight observation about that subject." ;
    rdfs:range hcm-obs:WeightObservation .

hcm-env:hasGasConcentrationProfile a owl:ObjectProperty ;
    rdfs:label "has gas concentration profile" ;
    rdfs:comment "Relates an environment profile to a gas concentration profile." ;
    rdfs:domain hcm-env:EnvironmentProfile ;
    rdfs:range hcm-env:GasConcentrationProfile .

hcm-env:hasGasType a owl:DatatypeProperty ;
    rdfs:label "has gas type" ;
    rdfs:comment "Records the gas type measured or specified in a gas concentration profile or observation." ;
    rdfs:range xsd:string .

hcm-env:hasLightCycle a owl:ObjectProperty ;
    rdfs:label "has light cycle" ;
    rdfs:comment "Relates an environment profile to a light cycle." ;
    rdfs:domain hcm-env:EnvironmentProfile ;
    rdfs:range hcm-env:LightCycle .

hcm-env:hasMeasurementSpec a owl:ObjectProperty ;
    rdfs:label "has measurement spec" ;
    rdfs:comment "Relates an environment profile to a measurement specification." ;
    rdfs:domain hcm-env:EnvironmentProfile ;
    rdfs:range hcm-env:MeasurementSpecification .

hcm-env:hasThriveProfile a owl:ObjectProperty ;
    rdfs:label "has thrive profile" ;
    rdfs:comment "Relates a monitored enclosure to the thrive profile that specifies suitable husbandry or environmental conditions." ;
    rdfs:domain hcm:MonitoredEnclosure ;
    rdfs:range hcm-env:ThriveProfile .

hcm-env:hasValue a owl:DatatypeProperty ;
    rdfs:label "has value" ;
    rdfs:comment "Records a literal value for an environmental measurement or specification." ;
    rdfs:range xsd:string .

hcm-obs:BehaviorResult a owl:Class ;
    rdfs:label "Behavior Result" ;
    rdfs:comment "An observation result representing a detected, classified, or recorded behavior." .

hcm-obs:QuantityValue a owl:Class ;
    rdfs:label "Quantity Value" ;
    rdfs:comment "An observation result that represents a quantitative value, typically with a numeric value and unit." .

hcm-obs:hasBehaviorType a owl:DatatypeProperty ;
    rdfs:label "has behavior type" ;
    rdfs:comment "Records the behavior type or behavior category associated with a behavior observation or result." ;
    rdfs:range xsd:string .

hcm-obs:hasCategory a owl:DatatypeProperty ;
    rdfs:label "has category" ;
    rdfs:comment "Records the category assigned to a categorical observation or result." ;
    rdfs:range xsd:string .

hcm-obs:hasHealthStatusTerm a owl:DatatypeProperty ;
    rdfs:label "has health status term" ;
    rdfs:comment "Records a textual or coded health-status term associated with a health-status observation." ;
    rdfs:range xsd:string .

hcm-obs:hasInterval a owl:DatatypeProperty ;
    rdfs:label "has interval" ;
    rdfs:comment "Records a time interval or duration associated with an observation or result." ;
    rdfs:range xsd:string .

hcm-obs:hasNumericValue a owl:DatatypeProperty ;
    rdfs:label "has numeric value" ;
    rdfs:comment "Records the numeric value of a quantity result or measurement." ;
    rdfs:range xsd:decimal .

hcm-tech:installedIn a owl:ObjectProperty ;
    rdfs:label "installed in" ;
    rdfs:comment "Relates a sensor or technical component to the monitored enclosure or setup in which it is installed." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-tech:Sensor hcm-tech:Hardware ) ] ;
    rdfs:range hcm:MonitoredEnclosure .

hcm-tech:monitoredBy a owl:ObjectProperty ;
    rdfs:label "monitored by" ;
    rdfs:comment "Relates a monitored enclosure, subject, process, or property to the sensor or monitoring component observing it." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm:MonitoredEnclosure hcm-obs:ObservationResult ) ] ;
    rdfs:range hcm-tech:Sensor .

hcm-tech:runsOn a owl:ObjectProperty ;
    rdfs:label "runs on" ;
    rdfs:comment "Relates software to the hardware or platform on which it executes." ;
    rdfs:domain hcm-tech:Software ;
    rdfs:range hcm-tech:Hardware .

hcm-tech:supportsEnclosure a owl:ObjectProperty ;
    rdfs:label "supports enclosure" ;
    rdfs:comment "Relates a technical component or system to the monitored enclosure that it supports." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-tech:Hardware hcm-tech:Sensor hcm-tech:Software ) ] ;
    rdfs:range hcm:MonitoredEnclosure .

semts:during a owl:ObjectProperty ;
    rdfs:label "during" ;
    rdfs:comment "SEMTS relation linking a data segment to the temporal entity during which it occurs." ;
    rdfs:domain semts:TimeSeriesSegment ;
    rdfs:range time:TemporalEntity .

semts:generated a owl:ObjectProperty ;
    rdfs:label "generated" ;
    rdfs:comment "SEMTS relation linking a result artifact to generated data such as a time-series segment." ;
    rdfs:domain hcm-obs:ObservationResult ;
    rdfs:range semts:TimeSeriesSegment .

semts:hasDimension a owl:ObjectProperty ;
    rdfs:label "has dimension" ;
    rdfs:comment "SEMTS relation linking a data artifact or observation to one of its data dimensions." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-obs:EnvironmentObservation hcm-obs:ObservationResult ) ] ;
    rdfs:range semts:DataDimension .

semts:isPartOf a owl:ObjectProperty ;
    rdfs:label "is part of" ;
    rdfs:comment "SEMTS relation linking a data segment or artifact to the larger artifact it is part of." ;
    rdfs:domain semts:TimeSeriesSegment ;
    rdfs:range hcm-obs:EnvironmentObservation .

time:TemporalEntity a owl:Class ;
    rdfs:label "Temporal Entity" ;
    rdfs:comment "OWL-Time class used for temporal entities referenced by HCMO observations and time-series segments." .

sosa:phenomenonTime a owl:ObjectProperty ;
    rdfs:label "phenomenon time" ;
    rdfs:comment "SOSA relation linking an observation to the time that the observed phenomenon occurred." .

hcm:Enrichment a owl:Class ;
    rdfs:label "Enrichment" ;
    rdfs:comment "A material, structure, or intervention provided within an enclosure to support animal welfare or experimental conditions." .

hcm:hasUnit a owl:DatatypeProperty ;
    rdfs:label "has unit" ;
    rdfs:comment "Records the measurement unit associated with a quantitative value." ;
    rdfs:range xsd:string .

hcm-env:GasConcentrationProfile a owl:Class ;
    rdfs:label "Gas Concentration Profile" ;
    rdfs:comment "A profile describing concentrations of gases relevant to the monitored enclosure environment." .

hcm-env:ThriveProfile a owl:Class ;
    rdfs:label "Thrive Profile" ;
    rdfs:comment "A welfare or husbandry profile describing environmental conditions intended to support animal thriving." .

hcm-obs:hasConfidenceScore a owl:DatatypeProperty ;
    rdfs:label "has confidence score" ;
    rdfs:comment "Records a numeric confidence score associated with an observation or inferred result." ;
    rdfs:range xsd:decimal .

sosa:observedProperty a owl:ObjectProperty ;
    rdfs:label "observed property" ;
    rdfs:comment "SOSA relation linking an observation to the property being observed." .

hcm-bio:HousingAssignment a owl:Class ;
    rdfs:label "Housing Assignment" ;
    rdfs:comment "A record assigning a subject or group to an enclosure in a study or housing context." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hcm-bio:assignedToEnclosure ;
            owl:someValuesFrom hcm:MonitoredEnclosure ] .

hcm-tech:TimeSeries a owl:Class ;
    rdfs:label "Time Series" ;
    rdfs:comment "An ordered sequence of time-indexed measurements or outputs produced in a monitoring workflow." ;
    rdfs:subClassOf hcm-obs:ObservationResult .

sosa:hasFeatureOfInterest a owl:ObjectProperty ;
    rdfs:label "has feature of interest" ;
    rdfs:comment "SOSA relation linking an observation to the entity, system, or feature being observed." ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( hcm-obs:BehaviorObservation hcm-obs:EnvironmentObservation hcm-obs:HealthStatusObservation hcm-obs:WeightObservation ) ] ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( hcm:MonitoredEnclosure hcm-bio:Subject ) ] .

sosa:hasResult a owl:ObjectProperty ;
    rdfs:label "has result" ;
    rdfs:comment "SOSA relation linking an observation to its result." .

semts:DataDimension a owl:Class ;
    rdfs:label "Data Dimension" ;
    rdfs:comment "SEMTS class used for dimensions of time-series or tabular data generated by an HCMO observation." .

sosa:resultTime a owl:DatatypeProperty ;
    rdfs:label "result time" ;
    rdfs:comment "SOSA property recording the instant at which an observation result became available." ;
    rdfs:range xsd:dateTime .

sosa:usedProcedure a owl:ObjectProperty ;
    rdfs:label "used procedure" ;
    rdfs:comment "SOSA relation linking an observation to the procedure used to make it." .

semts:TimeSeriesSegment a owl:Class ;
    rdfs:label "Time Series Segment" ;
    rdfs:comment "SEMTS class used for a segment of time-series data generated by a monitoring output." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty semts:isPartOf ;
            owl:someValuesFrom hcm-obs:EnvironmentObservation ],
        [ a owl:Restriction ;
            owl:onProperty semts:during ;
            owl:someValuesFrom time:TemporalEntity ] .

hcm-obs:BehaviorObservation a owl:Class ;
    rdfs:label "Behavior Observation" ;
    rdfs:comment "A SOSA-style observation about the behavior of a subject in a home-cage monitoring context." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sosa:hasFeatureOfInterest ;
            owl:someValuesFrom hcm-bio:Subject ],
        [ a owl:Restriction ;
            owl:onProperty sosa:hasResult ;
            owl:someValuesFrom hcm-obs:BehaviorResult ] .

hcm-obs:HealthStatusObservation a owl:Class ;
    rdfs:label "Health Status Observation" ;
    rdfs:comment "A SOSA-style observation about the health status of a biological subject." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sosa:hasFeatureOfInterest ;
            owl:someValuesFrom hcm-bio:Subject ] .

hcm-obs:WeightObservation a owl:Class ;
    rdfs:label "Weight Observation" ;
    rdfs:comment "A SOSA-style observation reporting the body weight of a biological subject." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:usedProcedure ],
        [ a owl:Restriction ;
            owl:onProperty sosa:hasFeatureOfInterest ;
            owl:someValuesFrom hcm-bio:Subject ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:observedProperty ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:resultTime ],
        hcm-obs:ObservationResult .

hcm:EnclosureDimensions a owl:Class ;
    rdfs:label "Enclosure Dimensions" ;
    rdfs:comment "A dimensions record describing the physical size of an enclosure." .

hcm-bio:ExperimentalGroup a owl:Class ;
    rdfs:label "Experimental Group" ;
    rdfs:comment "A group of biological subjects sharing an experimental condition, treatment, or study role." .

hcm-env:EnvironmentalProperty a owl:Class ;
    rdfs:label "Environmental Property" ;
    rdfs:comment "An environmental parameter that may be measured, specified, or controlled in a home-cage monitoring context." .

hcm-env:LightCycle a owl:Class ;
    rdfs:label "Light Cycle" ;
    rdfs:comment "A description of the timing and transitions of light and dark phases in an enclosure environment." .

hcm-tech:Actuator a owl:Class ;
    rdfs:label "Actuator" ;
    rdfs:comment "A device that elicits or perturbs behavior, physiology, or the monitored environment." .

schema:Person a owl:Class ;
    rdfs:label "Person" ;
    rdfs:comment "Schema.org class used to identify HCMO contributors in ontology metadata." .

hcm-bio:Subject a owl:Class ;
    rdfs:label "Subject" ;
    rdfs:comment "A biological individual, such as a laboratory animal, observed in a home-cage monitoring context." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom hcm-obs:BehaviorObservation ;
            owl:onProperty hcm-bio:hasBehaviorObservation ] .

hcm-env:MeasurementSpecification a owl:Class ;
    rdfs:label "Measurement Specification" ;
    rdfs:comment "A specification describing how an environmental property is measured, represented, or constrained." .

hcm-tech:Software a owl:Class ;
    rdfs:label "Software" ;
    rdfs:comment "Software component used to acquire, process, store, or analyse home-cage monitoring data." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hcm-tech:runsOn ;
            owl:someValuesFrom hcm-tech:Hardware ] .

hcm-env:EnvironmentProfile a owl:Class ;
    rdfs:label "Environment Profile" ;
    rdfs:comment "A structured profile describing environmental conditions or requirements for a monitored enclosure." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom hcm-env:MeasurementSpecification ;
            owl:onProperty hcm-env:hasMeasurementSpec ],
        [ a owl:Restriction ;
            owl:allValuesFrom hcm-env:LightCycle ;
            owl:onProperty hcm-env:hasLightCycle ],
        [ a owl:Restriction ;
            owl:allValuesFrom hcm-env:GasConcentrationProfile ;
            owl:onProperty hcm-env:hasGasConcentrationProfile ] .

hcm-obs:ObservationResult a owl:Class ;
    rdfs:label "Observation Result" ;
    rdfs:comment "A result produced by an observation, optionally linked to the sensor that made or generated it." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom hcm-tech:Sensor ;
            owl:onProperty sosa:madeBySensor ] .

hcm-tech:Hardware a owl:Class ;
    rdfs:label "Hardware" ;
    rdfs:comment "Physical computing hardware component of a home-cage monitoring system." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hcm-tech:supportsEnclosure ;
            owl:someValuesFrom hcm:MonitoredEnclosure ] ;
    owl:disjointWith hcm-tech:Software .

hcm:MonitoredEnclosure a owl:Class ;
    rdfs:label "Monitored Enclosure" ;
    rdfs:comment "A monitored housing unit that links an enclosure identifier, timing, animals, environmental profiles, sensors, and observations in HCMO." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:hasEnrichment ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:isOccupied ],
        [ a owl:Restriction ;
            owl:allValuesFrom hcm-bio:ExperimentalGroup ;
            owl:onProperty hcm-bio:belongsToGroup ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-bio:hasDateOfBirth ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:usedProcedure ],
        [ a owl:Restriction ;
            owl:allValuesFrom hcm-obs:HealthStatusObservation ;
            owl:onProperty hcm-bio:hasHealthStatusObservation ],
        [ a owl:Restriction ;
            owl:onProperty hcm-tech:monitoredBy ;
            owl:someValuesFrom hcm-tech:Sensor ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-obs:hasBehaviorType ],
        [ a owl:Restriction ;
            owl:allValuesFrom hcm-obs:WeightObservation ;
            owl:onProperty hcm-bio:hasWeightObservation ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:usedProcedure ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-obs:hasInterval ],
        [ a owl:Restriction ;
            owl:allValuesFrom hcm-env:ThriveProfile ;
            owl:onProperty hcm-env:hasThriveProfile ],
        [ a owl:Restriction ;
            owl:onProperty hcm:hasDimensions ;
            owl:someValuesFrom hcm:EnclosureDimensions ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty time:hasBeginning ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-env:hasValue ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:observedProperty ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-bio:hasStrain ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:hasResult ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:hasEnclosureIdentifier ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-obs:hasConfidenceScore ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:hasUnit ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:hasWidth ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:hasDimUnit ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:hasManufacturer ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-obs:hasHealthStatusTerm ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:resultTime ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-bio:hasBiologicalSex ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:isOperational ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:hasHeight ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:usedProcedure ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty time:inXSDDateTime ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-bio:hasSpecies ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:hasLength ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-env:hasGasType ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-obs:hasNumericValue ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty time:hasEnd ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:resultTime ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:phenomenonTime ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:locatedIn ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:observedProperty ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-obs:hasConfidenceScore ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm:hasUnit ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:resultTime ],
        hcm:Enclosure .

hcm-obs:EnvironmentObservation a owl:Class ;
    rdfs:label "Environment Observation" ;
    rdfs:comment "A SOSA-style observation about an environmental property of a monitored enclosure." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sosa:hasFeatureOfInterest ;
            owl:someValuesFrom hcm:MonitoredEnclosure ],
        [ a owl:Restriction ;
            owl:allValuesFrom semts:DataDimension ;
            owl:onProperty semts:hasDimension ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty hcm-obs:hasCategory ] .

hcm:Enclosure a owl:Class ;
    rdfs:label "Enclosure" ;
    rdfs:comment "A physical housing enclosure used as part of a home-cage monitoring system." .

hcm-tech:Sensor a owl:Class ;
    rdfs:label "Sensor" ;
    rdfs:comment "A device that captures signals related to behavior, physiology, or enclosure environment." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hcm-tech:installedIn ;
            owl:someValuesFrom hcm:MonitoredEnclosure ] ;
    owl:disjointWith hcm-tech:Actuator .

