hcm:installedIn a owl:ObjectProperty ;
    rdfs:label "installed in" .

hcm:locatedIn a owl:DatatypeProperty ;
    rdfs:label "located in" .

hcm:monitoredBy a owl:ObjectProperty ;
    rdfs:label "monitored by" .

semts:TimeSeriesSegment a owl:Class ;
    rdfs:label "Time Series Segment" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty semts:during ;
            owl:someValuesFrom time:TemporalEntity ],
        [ a owl:Restriction ;
            owl:onProperty semts:isPartOf ;
            owl:someValuesFrom hcm-obs:EnvironmentObservation ] .

semts:during a owl:ObjectProperty ;
    rdfs:label "during" .

semts:generated a owl:ObjectProperty ;
    rdfs:label "generated" .

semts:isPartOf a owl:ObjectProperty ;
    rdfs:label "is part of" .

sosa:hasResult a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "has result" .

sosa:observedProperty a owl:DatatypeProperty,
        owl:ObjectProperty ;
    rdfs:label "observed property" .

sosa:phenomenonTime a owl:DatatypeProperty ;
    rdfs:label "phenomenon time" .

hcm:ObservationResult a owl:Class ;
    rdfs:label "Observation Result" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hcm:hasResult ;
            owl:someValuesFrom hcm:MonitoredEnclosure ],
        [ a owl:Restriction ;
            owl:allValuesFrom hcm:Sensor ;
            owl:onProperty sosa:madeBySensor ] .

hcm:Sensor a owl:Class ;
    rdfs:label "Sensor" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hcm:installedIn ;
            owl:someValuesFrom hcm:MonitoredEnclosure ] .

sosa:resultTime a owl:DatatypeProperty ;
    rdfs:label "result time" .

sosa:usedProcedure a owl:DatatypeProperty ;
    rdfs:label "used procedure" .

hcm:MonitoredEnclosure a owl:Class ;
    rdfs:label "Monitored Enclosure" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty hcm-bio:hasHousingAssignment ;
            owl:someValuesFrom hcm:MonitoredEnclosure ],
        [ a owl:Restriction ;
            owl:allValuesFrom hcm:MonitoredEnclosure ;
            owl:onProperty hcm:hasThriveProfile ],
        [ a owl:Restriction ;
            owl:onProperty hcm-bio:hasMember ;
            owl:someValuesFrom hcm:MonitoredEnclosure ],
        [ a owl:Restriction ;
            owl:allValuesFrom hcm:Software ;
            owl:onProperty sosa:madeObservation ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty UNKNOWN:isOperational ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty UNKNOWN:isOccupied ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
