# ARCHIVED HCMO/MAPP 0.0.1 source module: hcm-core
# Part of the MAPP (Monitoring and Analytics for Physiological Processes) ontology.
# Namespace: https://w3id.org/hcmo/ontology/hcm# (+ /bio#, /env#, /obs# per module).
# Contributors are recorded on the owl:Ontology header (dcterms:creator);
# ORCID IRIs are used where known. Edit modules here; regenerate dist/ with:
#   python tooling/build.py
#
@prefix UNKNOWN: <http://www.owl-ontologies.com/UNKNOWN#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix hcm: <https://w3id.org/hcmo/ontology/hcm#> .
@prefix hcm-bio: <https://w3id.org/hcmo/ontology/hcm/bio#> .
@prefix hcm-env: <https://w3id.org/hcmo/ontology/hcm/env#> .
@prefix hcm-obs: <https://w3id.org/hcmo/ontology/hcm/obs#> .
@prefix IAO: <http://purl.obolibrary.org/obo/IAO_> .
@prefix mod: <https://w3id.org/mod#> .
@prefix ns: <http://www.owl-ontologies.com/ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix semts: <https://w3id.org/semts/ontology/120#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dc:creator a owl:AnnotationProperty .

dc:description a owl:AnnotationProperty .

dc:title a owl:AnnotationProperty .

hcm:StudyFactors a owl:Class ;
    rdfs:label "Study Factors" ;
    rdfs:subClassOf hcm:MonitoredEnclosure .

UNKNOWN:captures a owl:DatatypeProperty ;
    rdfs:label "captures" .

UNKNOWN:communicatesWith a owl:ObjectProperty ;
    rdfs:label "communicates with" .

UNKNOWN:hasActuators a owl:DatatypeProperty ;
    rdfs:label "has actuators" .

UNKNOWN:hasCondition a owl:DatatypeProperty ;
    rdfs:label "has condition" .

UNKNOWN:hasDarkPhaseDuration a owl:DatatypeProperty ;
    rdfs:label "has dark phase duration" .

UNKNOWN:hasDarkPhaseStart a owl:DatatypeProperty ;
    rdfs:label "has dark phase start" .

UNKNOWN:hasDawnDuration a owl:DatatypeProperty ;
    rdfs:label "has dawn duration" .

UNKNOWN:hasDuskDuration a owl:DatatypeProperty ;
    rdfs:label "has dusk duration" .

UNKNOWN:hasEnrichmentReq a owl:ObjectProperty ;
    rdfs:label "has enrichment req" .

UNKNOWN:hasEnrichmentType a owl:DatatypeProperty ;
    rdfs:label "has enrichment type" .

UNKNOWN:hasFacilityType a owl:DatatypeProperty ;
    rdfs:label "has facility type" .

UNKNOWN:hasFirmware a owl:DatatypeProperty ;
    rdfs:label "has firmware" .

UNKNOWN:hasFloorArea a owl:DatatypeProperty ;
    rdfs:label "has floor area" .

UNKNOWN:hasFoodReq a owl:DatatypeProperty ;
    rdfs:label "has food req" .

UNKNOWN:hasLightPhaseDuration a owl:DatatypeProperty ;
    rdfs:label "has light phase duration" .

UNKNOWN:hasModelNumber a owl:DatatypeProperty ;
    rdfs:label "has model number" .

UNKNOWN:hasName a owl:DatatypeProperty ;
    rdfs:label "has name" ;
    rdfs:range xsd:string .

UNKNOWN:hasProtocol a owl:DatatypeProperty ;
    rdfs:label "has protocol" .

UNKNOWN:hasSafetyReq a owl:DatatypeProperty ;
    rdfs:label "has safety req" .

UNKNOWN:hasSamplingRate a owl:DatatypeProperty ;
    rdfs:label "has sampling rate" .

UNKNOWN:hasSensorIdentifier a owl:DatatypeProperty ;
    rdfs:label "has sensor identifier" .

UNKNOWN:hasSensorTechnology a owl:DatatypeProperty ;
    rdfs:label "has sensor technology" .

UNKNOWN:hasSensorType a owl:DatatypeProperty ;
    rdfs:label "has sensor type" .

UNKNOWN:hasSensors a owl:ObjectProperty ;
    rdfs:label "has sensors" .

UNKNOWN:hasSocialReq a owl:DatatypeProperty ;
    rdfs:label "has social req" .

UNKNOWN:hasType a owl:DatatypeProperty ;
    rdfs:label "has type" .

hcm:hasVersion a owl:DatatypeProperty ;
    rdfs:label "has version" .

UNKNOWN:hasWaterReq a owl:DatatypeProperty ;
    rdfs:label "has water req" .

UNKNOWN:isCalibrated a owl:DatatypeProperty ;
    rdfs:label "is calibrated" .

UNKNOWN:partOF a owl:DatatypeProperty ;
    rdfs:label "part o f" .

UNKNOWN:runsOn a owl:ObjectProperty ;
    rdfs:label "runs on" .

UNKNOWN:supportsEnclosure a owl:ObjectProperty ;
    rdfs:label "supports enclosure" .

ns:objectProperty a owl:ObjectProperty ;
    rdfs:label "object property" .

xsd:boolean a owl:DatatypeProperty ;
    rdfs:label "boolean" .

xsd:integer a owl:DatatypeProperty ;
    rdfs:label "integer" .

owl:versionInfo a owl:AnnotationProperty .

sosa:hasFeatureOfInterest a owl:ObjectProperty ;
    rdfs:label "has feature of interest" .

<https://w3id.org/hcmo/ontology/hcm> a owl:Ontology ;
    dc:description "Ontology for Monitoring and Analytics for Physiological Processes (MAPP)" ;
    dc:title "MAPP Ontology" ;
    dcterms:creator <https://orcid.org/0000-0002-2923-9790>,
        <https://orcid.org/0000-0002-6085-6818>,
        <https://orcid.org/0000-0002-9116-6692>,
        <https://orcid.org/0000-0003-2204-2466>,
        <https://orcid.org/0000-0003-4820-7951>,
        <https://orcid.org/0009-0008-0575-8490>,
        <https://orcid.org/0009-0008-2489-8106> ;
    owl:versionIRI <https://w3id.org/hcmo/ontology/hcm/0.0.1> ;
    owl:versionInfo "0.0.1" ;
    mod:createdWith <https://chowlk.linkeddata.es/> .

hcm:CategoricalResult a owl:Class ;
    rdfs:label "Categorical Result" .

hcm:System a owl:Class ;
    rdfs:label "System" ;
    rdfs:comment "A home-cage monitoring system comprising an enclosure, hardware, and software." ;
    IAO:0000115 "A home-cage monitoring system comprising an enclosure, hardware, and software." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:Enclosure a owl:Class ;
    rdfs:label "Enclosure" ;
    rdfs:comment "A physical housing enclosure used as part of a home-cage monitoring system." ;
    IAO:0000115 "A physical housing enclosure used as part of a home-cage monitoring system." ;
    dcterms:source "HCMO active ABox examples and user-submission form mapping." .

hcm:Enrichment a owl:Class ;
    rdfs:label "Enrichment" .

hcm:Hardware a owl:Class ;
    rdfs:label "Hardware" ;
    rdfs:comment "Physical computing hardware component of a home-cage monitoring system." ;
    IAO:0000115 "Physical computing hardware component of a home-cage monitoring system." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:OWL-Timeintervaltable a owl:Class ;
    rdfs:label "O W L- Timeintervaltable" .

hcm:PhysicalSpace a owl:Class ;
    rdfs:label "Physical Space" ;
    rdfs:comment "A spatial region associated with an enclosure." ;
    IAO:0000115 "A spatial region associated with an enclosure." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:Dimensions a owl:Class ;
    rdfs:label "Dimensions" ;
    rdfs:comment "Geometric dimensions of a physical space or enclosure." ;
    IAO:0000115 "Geometric dimensions of a physical space or enclosure." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:Actuator a owl:Class ;
    rdfs:label "Actuator" ;
    rdfs:comment "A device that elicits or perturbs behavior or physiology." ;
    IAO:0000115 "A device that elicits or perturbs behavior or physiology." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:Animal a owl:Class ;
    rdfs:label "Animal" ;
    rdfs:comment "An experimental animal housed in an enclosure." ;
    IAO:0000115 "An experimental animal housed in an enclosure." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:BehaviorAndPhysiology a owl:Class ;
    rdfs:label "Behavior and Physiology" ;
    rdfs:comment "Observed behavioral or physiological process displayed by an animal." ;
    IAO:0000115 "An observed behavioral or physiological process displayed by an animal." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:CircadianRhythm a owl:Class ;
    rdfs:label "Circadian Rhythm" ;
    rdfs:comment "A circadian rhythm associated with a behavior or physiology process." ;
    IAO:0000115 "A circadian rhythm associated with a behavior or physiology process." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:NeedsSequence a owl:Class ;
    owl:deprecated "true"^^xsd:boolean ;
    rdfs:label "Needs Sequence" ;
    rdfs:comment "Legacy boolean need-profile record used by current examples; prefer a future object-based need profile for richer modeling." ;
    IAO:0000115 "Legacy boolean need-profile record used by current examples." ;
    dcterms:source "HCMO active ABox examples." .

hcm:ObservationWindow a owl:Class ;
    rdfs:label "Observation Window" ;
    rdfs:comment "An observation time window for behavior capture." ;
    IAO:0000115 "An observation time window for behavior capture." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:TimeInterval a owl:Class ;
    owl:deprecated "true"^^xsd:boolean ;
    rdfs:subClassOf hcm:ObservationWindow ;
    rdfs:label "Time Interval" ;
    rdfs:comment "Deprecated; use hcm:ObservationWindow." ;
    IAO:0000115 "Deprecated; use hcm:ObservationWindow." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:LimitedInteractionWithHumans a owl:Class ;
    rdfs:label "Limited Interaction With Humans" ;
    rdfs:comment "A condition indicating minimal human interference during observation." ;
    IAO:0000115 "A condition indicating minimal human interference during observation." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:Protocol a owl:Class ;
    rdfs:label "Protocol" ;
    rdfs:comment "A protocol, SOP, or approval reference governing a system submission." ;
    IAO:0000115 "A protocol, SOP, or approval reference governing a system submission." ;
    dcterms:source "HCMO user-submission form mapping." .

hcm:ContactPoint a owl:Class ;
    rdfs:label "Contact Point" ;
    rdfs:comment "Contact detail associated with a submitted system or supplier." ;
    IAO:0000115 "Contact detail associated with a submitted system or supplier." ;
    dcterms:source "HCMO user-submission form mapping." .

hcm:DataProduct a owl:Class ;
    rdfs:label "Data Product" ;
    rdfs:comment "Data artifact or link associated with a submitted system." ;
    IAO:0000115 "Data artifact or link associated with a submitted system." ;
    dcterms:source "HCMO user-submission form mapping." .

hcm:Supplier a owl:Class ;
    rdfs:label "Supplier" ;
    rdfs:comment "Commercial supplier or laboratory providing the system." ;
    IAO:0000115 "A commercial supplier or laboratory providing the system." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

<https://w3id.org/hcmo/ontology/hcm#Structural&LocationTable> a owl:Class ;
    rdfs:label "Structural& Location Table" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sosa:hasResult ;
            owl:someValuesFrom hcm:QuantityValue ],
        [ a owl:Restriction ;
            owl:onProperty semts:generated ;
            owl:someValuesFrom semts:TimeSeriesSegment ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:resultTime ],
        [ a owl:Restriction ;
            owl:cardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:phenomenonTime ],
        [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty sosa:usedProcedure ],
        hcm:ObservationResult .

hcm:TimeSeries a owl:Class ;
    rdfs:label "Time Series" .

hcm:hasCapacity a owl:DatatypeProperty ;
    rdfs:label "has capacity" .

hcm:hasCategory a owl:DatatypeProperty ;
    rdfs:label "has category" .

hcm:hasDescription a owl:DatatypeProperty ;
    rdfs:label "has description" .

hcm:hasEnvironment a owl:DatatypeProperty ;
    rdfs:label "has environment" .

hcm:hasFileFormat a owl:DatatypeProperty ;
    rdfs:label "has file format" .

hcm:hasMonitoredAnimals a owl:DatatypeProperty ;
    rdfs:label "has monitored animals" .

hcm:hasSamplingRate a owl:DatatypeProperty ;
    rdfs:label "has sampling rate" .

hcm:hasStoragePath a owl:DatatypeProperty ;
    rdfs:label "has storage path" .

hcm:isOccupied a owl:DatatypeProperty ;
    rdfs:label "is occupied" .

semts:DataDimension a owl:Class ;
    rdfs:label "Data Dimension" .

semts:dimensionUnit a owl:DatatypeProperty ;
    rdfs:label "dimension unit" .

semts:hasDimension a owl:ObjectProperty ;
    rdfs:label "has dimension" .

semts:title a owl:DatatypeProperty ;
    rdfs:label "title" .

UNKNOWN:isOccupied a owl:DatatypeProperty ;
    rdfs:label "is occupied" .

UNKNOWN:isOperational a owl:DatatypeProperty ;
    rdfs:label "is operational" .

time:TemporalEntity a owl:Class ;
    rdfs:label "Temporal Entity" .

time:hasBeginning a owl:DatatypeProperty ;
    rdfs:label "has beginning" .

time:hasEnd a owl:DatatypeProperty ;
    rdfs:label "has end" .

time:inXSDDateTime a owl:DatatypeProperty ;
    rdfs:label "in x s d date time" .

sosa:madeBySensor a owl:ObjectProperty ;
    rdfs:label "made by sensor" .

sosa:madeObservation a owl:ObjectProperty ;
    rdfs:label "made observation" .

<https://orcid.org/0000-0002-2923-9790> a schema:Person ;
    schema:name "Pierre Larmande" .

<https://orcid.org/0000-0002-6085-6818> a schema:Person ;
