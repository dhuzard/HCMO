<https://orcid.org/0009-0008-2489-8106> a schema:Person ;
    schema:name "Cyril Gilbert" .

hcm:QuantityValue a owl:Class ;
    rdfs:label "Quantity Value" .

hcm:Software a owl:Class ;
    rdfs:label "Software" ;
    rdfs:comment "Software component of a home-cage monitoring system." ;
    IAO:0000115 "Software component of a home-cage monitoring system." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:hasEnclosure a owl:ObjectProperty ;
    rdfs:label "has enclosure" ;
    rdfs:domain hcm:System ;
    rdfs:range hcm:Enclosure ;
    rdfs:comment "Links a system to its enclosure." ;
    IAO:0000115 "Relates a system to the enclosure that is part of it." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:hasDimensions a owl:ObjectProperty ;
    rdfs:label "has dimensions" ;
    rdfs:range hcm:Dimensions ;
    rdfs:comment "Links a physical space or enclosure to its dimensions record." ;
    IAO:0000115 "Relates a physical space or enclosure to its dimensions record." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:hasSpaceRegion a owl:ObjectProperty ;
    rdfs:label "has space region" ;
    rdfs:domain hcm:Enclosure ;
    rdfs:range hcm:PhysicalSpace ;
    rdfs:comment "Links an enclosure to the physical space it contains or bounds." ;
    IAO:0000115 "Relates an enclosure to the physical space it contains or bounds." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:hasHardware a owl:ObjectProperty ;
    rdfs:label "has hardware" ;
    rdfs:domain hcm:System ;
    rdfs:range hcm:Hardware ;
    rdfs:comment "Links a system to its hardware component." ;
    IAO:0000115 "Relates a system to a hardware component that is part of it." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:hasSoftware a owl:ObjectProperty ;
    rdfs:label "has software" ;
    rdfs:domain hcm:System ;
    rdfs:range hcm:Software ;
    rdfs:comment "Links a system to its software component." ;
    IAO:0000115 "Relates a system to a software component that is part of it." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:producedBy a owl:ObjectProperty ;
    rdfs:label "produced by" ;
    rdfs:domain hcm:System ;
    rdfs:range hcm:Supplier ;
    rdfs:comment "Links a system to the supplier or laboratory that produced it." ;
    IAO:0000115 "Relates a system to the supplier or laboratory that produced it." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:hasSensor a owl:ObjectProperty ;
    rdfs:label "has sensor" ;
    rdfs:domain hcm:System ;
    rdfs:range hcm:Sensor ;
    rdfs:comment "Relates a system to a sensor associated with it." ;
    IAO:0000115 "Relates a system to a sensor associated with it." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:collectsInfoOn a owl:ObjectProperty ;
    rdfs:label "collects info on" ;
    rdfs:domain hcm:System ;
    rdfs:range hcm:Animal ;
    rdfs:comment "Relates a system to an animal or animal record it collects information on." ;
    IAO:0000115 "Relates a system to an animal or animal record it collects information on." ;
    dcterms:source "HCMO active ABox examples and user-submission form mapping." .

hcm:followsProtocol a owl:ObjectProperty ;
    rdfs:label "follows protocol" ;
    rdfs:domain hcm:System ;
    rdfs:range hcm:Protocol ;
    rdfs:comment "Relates a system submission to a governing protocol or SOP reference." ;
    IAO:0000115 "Relates a system submission to a governing protocol or SOP reference." ;
    dcterms:source "HCMO user-submission form mapping." .

hcm:livesIn a owl:ObjectProperty ;
    rdfs:label "lives in" ;
    rdfs:domain hcm:Animal ;
    rdfs:range hcm:Enclosure ;
    rdfs:comment "Relates an animal to the enclosure it lives in." ;
    IAO:0000115 "Relates an animal to the enclosure it lives in." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:requiresToThrive a owl:ObjectProperty ;
    rdfs:label "requires to thrive" ;
    rdfs:domain hcm:Animal ;
    rdfs:range hcm:NeedsSequence ;
    rdfs:comment "Relates an animal to the need profile it requires." ;
    IAO:0000115 "Relates an animal to the need profile it requires." ;
    dcterms:source "HCMO active ABox examples." .

hcm:provides a owl:ObjectProperty ;
    rdfs:label "provides" ;
    rdfs:domain hcm:Enclosure ;
    rdfs:range hcm:NeedsSequence ;
    rdfs:comment "Relates an enclosure to a need profile it provides." ;
    IAO:0000115 "Relates an enclosure to a need profile it provides." ;
    dcterms:source "HCMO active ABox examples." .

hcm:displays a owl:ObjectProperty ;
    rdfs:label "displays" ;
    rdfs:domain hcm:Animal ;
    rdfs:range hcm:BehaviorAndPhysiology ;
    rdfs:comment "Relates an animal to a behavior or physiology process it displays." ;
    IAO:0000115 "Relates an animal to a behavior or physiology process it displays." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:isDisplayedInside a owl:ObjectProperty ;
    rdfs:label "is displayed inside" ;
    rdfs:domain hcm:BehaviorAndPhysiology ;
    rdfs:range hcm:Enclosure ;
    rdfs:comment "Relates a behavior or physiology process to the enclosure where it occurs." ;
    IAO:0000115 "Relates a behavior or physiology process to the enclosure where it occurs." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:hasCircadianRhythm a owl:ObjectProperty ;
    rdfs:label "has circadian rhythm" ;
    rdfs:domain hcm:BehaviorAndPhysiology ;
    rdfs:range hcm:CircadianRhythm ;
    rdfs:comment "Relates a behavior or physiology process to its circadian rhythm." ;
    IAO:0000115 "Relates a behavior or physiology process to its circadian rhythm." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:extendsEnoughToCapture a owl:ObjectProperty ;
    owl:deprecated "true"^^xsd:boolean ;
    rdfs:label "extends enough to capture" ;
    rdfs:domain hcm:BehaviorAndPhysiology ;
    rdfs:range hcm:ObservationWindow ;
    rdfs:comment "Deprecated legacy relation from a behavior process to a sufficient observation window." ;
    IAO:0000115 "Deprecated legacy relation from a behavior process to a sufficient observation window." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:hasProperty a owl:ObjectProperty ;
    owl:deprecated "true"^^xsd:boolean ;
    rdfs:label "has property" ;
    rdfs:domain hcm:ObservationWindow ;
    rdfs:range hcm:LimitedInteractionWithHumans ;
    rdfs:comment "Deprecated legacy relation from an observation window to an observation condition." ;
    IAO:0000115 "Deprecated legacy relation from an observation window to an observation condition." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:captures a owl:ObjectProperty ;
    rdfs:label "captures" ;
    rdfs:domain hcm:Sensor ;
    rdfs:range hcm:BehaviorAndPhysiology ;
    rdfs:comment "Relates a sensor to a behavior or physiology process it captures." ;
    IAO:0000115 "Relates a sensor to a behavior or physiology process it captures." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:elicits a owl:ObjectProperty ;
    rdfs:label "elicits" ;
    rdfs:domain hcm:Actuator ;
    rdfs:range hcm:BehaviorAndPhysiology ;
    rdfs:comment "Relates an actuator to a behavior or physiology process it elicits or perturbs." ;
    IAO:0000115 "Relates an actuator to a behavior or physiology process it elicits or perturbs." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:communicatesWith a owl:ObjectProperty ;
    rdfs:label "communicates with" ;
    rdfs:domain hcm:Hardware ;
    rdfs:range hcm:Software ;
    rdfs:comment "Relates hardware to software that it communicates with." ;
    IAO:0000115 "Relates hardware to software that it communicates with." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:hasActuator a owl:ObjectProperty ;
    rdfs:label "has actuator" ;
    rdfs:domain hcm:System ;
    rdfs:range hcm:Actuator ;
    rdfs:comment "Relates a system to an actuator associated with it." ;
    IAO:0000115 "Relates a system to an actuator associated with it." ;
    dcterms:source "2022-04-28-hcm-OLOG_WEB_FRIENDLY" .

hcm:hasEnclosureIdentifier a owl:DatatypeProperty ;
    rdfs:label "has enclosure identifier" .

hcm:hasEnrichment a owl:DatatypeProperty ;
    rdfs:label "has enrichment" .

hcm:hasManufacturer a owl:DatatypeProperty ;
    rdfs:label "has manufacturer" .

hcm:hasName a owl:DatatypeProperty ;
    rdfs:label "has name" ;
    rdfs:range xsd:string .

hcm:hasNumericValue a owl:DatatypeProperty ;
    rdfs:label "has numeric value" .

hcm:hasResult a owl:ObjectProperty ;
    rdfs:label "has result" .

hcm:hasThriveProfile a owl:ObjectProperty ;
    rdfs:label "has thrive profile" .

hcm:hasUnit a owl:DatatypeProperty ;
    rdfs:label "has unit" .

hcm:protocolReference a owl:DatatypeProperty ;
    rdfs:label "protocol reference" ;
    rdfs:domain hcm:Protocol ;
    rdfs:range xsd:string ;
    rdfs:comment "Textual protocol, SOP, DOI, or approval reference." ;
    IAO:0000115 "Textual protocol, SOP, DOI, or approval reference." ;
    dcterms:source "HCMO user-submission form mapping." .

hcm:durationHours a owl:DatatypeProperty ;
    rdfs:label "duration hours" ;
    rdfs:domain hcm:ObservationWindow ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Duration of an observation window in hours." ;
