            owl:onProperty hcm-env:hasDimUnit ],
        [ a owl:Restriction ;
            owl:onProperty hcm-obs: ;
            owl:someValuesFrom hcm-bio:Subject ],
        [ a owl:Restriction ;
            owl:onProperty hcm-obs:assignedToEnclosure ;
            owl:someValuesFrom hcm:MonitoredEnclosure ],
        [ a owl:Restriction ;
            owl:onProperty hcm:hasDimensions ;
            owl:someValuesFrom hcm-env:EnclosureDimensions ],
        [ a owl:Restriction ;
