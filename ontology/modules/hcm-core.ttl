# HCMO 0.2.0 — core — the MonitoredEnclosure hub + reused-vocabulary scaffolding + ontology header
# Promoted after expert review; see docs/paper/MODULE-MAP.md. Namespace policy: …/hcm#.
#
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix BFO: <http://purl.obolibrary.org/obo/BFO_> .
@prefix hcm: <https://w3id.org/hcmo/ontology/hcm#> .
@prefix hcm-bio: <https://w3id.org/hcmo/ontology/hcm/bio#> .
@prefix hcm-env: <https://w3id.org/hcmo/ontology/hcm/env#> .
@prefix hcm-obs: <https://w3id.org/hcmo/ontology/hcm/obs#> .
@prefix hcm-tech: <https://w3id.org/hcmo/ontology/hcm/tech#> .
@prefix IAO: <http://purl.obolibrary.org/obo/IAO_> .
@prefix mod: <https://w3id.org/mod#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix semts: <https://w3id.org/semts/ontology/120#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

bibo:doi a owl:AnnotationProperty .

dc:creator a owl:AnnotationProperty .

dc:description a owl:AnnotationProperty .

dc:title a owl:AnnotationProperty .

dcterms:bibliographicCitation a owl:AnnotationProperty .

dcterms:created a owl:AnnotationProperty .

dcterms:creator a owl:AnnotationProperty .

dcterms:identifier a owl:AnnotationProperty .

dcterms:issued a owl:AnnotationProperty .

dcterms:license a owl:AnnotationProperty .

dcterms:modified a owl:AnnotationProperty .

dcterms:publisher a owl:AnnotationProperty .

dcterms:source a owl:AnnotationProperty .

mod:createdWith a owl:AnnotationProperty .

mod:status a owl:AnnotationProperty .

owl:versionInfo a owl:AnnotationProperty .

schema:logo a owl:AnnotationProperty .

vann:preferredNamespacePrefix a owl:AnnotationProperty .

vann:preferredNamespaceUri a owl:AnnotationProperty .

<https://w3id.org/hcmo/ontology/hcm> a owl:Ontology ;
    dc:description "Ontology for home-cage monitoring of laboratory animals" ;
    dc:title "Home-Cage Monitoring Ontology" ;
    bibo:doi "10.5281/zenodo.18925285" ;
    dcterms:bibliographicCitation "The Home-Cage Monitoring Ontology (HCMO). Zenodo. https://doi.org/10.5281/zenodo.18925285" ;
    dcterms:created "2026-03-09"^^xsd:date ;
    bibo:authorList ( <https://orcid.org/0000-0003-4820-7951>
        <https://orcid.org/0000-0002-9116-6692>
        <https://orcid.org/0009-0008-2489-8106>
        <https://orcid.org/0000-0002-2923-9790>
        <https://orcid.org/0000-0003-2204-2466>
        <https://orcid.org/0000-0002-6085-6818>
        <https://orcid.org/0009-0008-0575-8490> ) ;
    dcterms:creator <https://orcid.org/0000-0003-4820-7951>,
        <https://orcid.org/0000-0002-2923-9790>,
        <https://orcid.org/0000-0002-6085-6818>,
        <https://orcid.org/0000-0002-9116-6692>,
        <https://orcid.org/0000-0003-2204-2466>,
        <https://orcid.org/0009-0008-0575-8490>,
        <https://orcid.org/0009-0008-2489-8106> ;
    dcterms:identifier "https://doi.org/10.5281/zenodo.18925285" ;
    dcterms:issued "2026-03-09"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:modified "2026-07-17"^^xsd:date ;
    dcterms:publisher "Huzard group" ;
    dcterms:source <https://github.com/dhuzard/HCMO> ;
    owl:priorVersion <https://w3id.org/hcmo/ontology/hcm/0.1.0> ;
    owl:versionIRI <https://w3id.org/hcmo/ontology/hcm/0.2.0> ;
    owl:versionInfo "0.2.0" ;
    schema:logo <https://raw.githubusercontent.com/dhuzard/HCMO/main/HCMO-logo3.png> ;
    mod:createdWith <https://chowlk.linkeddata.es/> ;
    mod:status "draft" ;
    vann:preferredNamespacePrefix "hcm" ;
    vann:preferredNamespaceUri "https://w3id.org/hcmo/ontology/hcm#" .

hcm:Enclosure a owl:Class ;
    rdfs:label "Enclosure" ;
    rdfs:comment "A physical housing enclosure used as part of a home-cage monitoring system." ;
    rdfs:subClassOf BFO:0000040 .

hcm:Enrichment a owl:Class ;
    rdfs:label "Enrichment" ;
    rdfs:comment "A material or structure provided within an enclosure to support animal welfare or experimental conditions." ;
    rdfs:subClassOf BFO:0000040 .

hcm:hasEnrichmentRequirement a owl:DatatypeProperty ;
    rdfs:label "has enrichment requirement" ;
    rdfs:comment "Records a textual or coded enrichment requirement for an enclosure or monitored enclosure." ;
    rdfs:domain hcm:Enclosure ;
    rdfs:range xsd:string .

hcm:hasCapacity a owl:DatatypeProperty ;
    rdfs:label "has capacity" ;
    rdfs:comment "Records the intended capacity of an enclosure, such as the number of animals it can house." ;
    rdfs:domain hcm:Enclosure ;
    rdfs:range xsd:nonNegativeInteger .

hcm:hasDescription a owl:DatatypeProperty ;
    rdfs:label "has description" ;
    rdfs:comment "Provides a textual description for an HCMO resource." ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string .

hcm:hasMonitoredAnimals a owl:ObjectProperty ;
    rdfs:label "has monitored animals" ;
    rdfs:comment "Relates a monitored enclosure to the biological subjects housed or tracked within it." ;
    rdfs:domain hcm:MonitoredEnclosure ;
    rdfs:range hcm-bio:Subject .

hcm:hasName a owl:DatatypeProperty ;
    rdfs:label "has name" ;
    rdfs:comment "Records a human-readable name for an HCMO resource." ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:string .

hcm:isOccupied a owl:DatatypeProperty ;
    rdfs:label "is occupied" ;
    rdfs:comment "Indicates whether an enclosure is currently occupied by animals." ;
    rdfs:domain hcm:Enclosure ;
    rdfs:range xsd:boolean .

hcm:isOperational a owl:DatatypeProperty ;
    rdfs:label "is operational" ;
    rdfs:comment "Indicates whether a monitored enclosure is currently operational." ;
    rdfs:domain hcm:MonitoredEnclosure ;
    rdfs:range xsd:boolean .

<https://orcid.org/0000-0002-2923-9790> a schema:Person ;
    schema:name "Pierre Larmande" .

<https://orcid.org/0000-0002-6085-6818> a schema:Person ;
    schema:name "Serge Sonfack Sounchio" .

<https://orcid.org/0000-0002-9116-6692> a schema:Person ;
    schema:name "Konstantin Todorov" .

<https://orcid.org/0000-0003-2204-2466> a schema:Person ;
    schema:name "Gaoussou Sanou" .

<https://orcid.org/0000-0003-4820-7951> a schema:Person ;
    schema:name "Damien Huzard" .

<https://orcid.org/0009-0008-0575-8490> a schema:Person ;
    schema:name "Antoine Toffano" .

<https://orcid.org/0009-0008-2489-8106> a schema:Person ;
    schema:name "Cyril Gilbert" .

hcm:EnclosureDimensions a owl:Class ;
    rdfs:label "Enclosure Dimensions" ;
    rdfs:comment "A dimensions record describing the physical size of an enclosure." ;
    rdfs:subClassOf IAO:0000030 .

hcm:hasDimUnit a owl:DatatypeProperty ;
    rdfs:label "has dim unit" ;
    rdfs:comment "Records the unit used for enclosure dimension values." ;
    rdfs:domain hcm:EnclosureDimensions ;
    rdfs:range xsd:string .

hcm:hasDimensions a owl:ObjectProperty ;
    rdfs:label "has dimensions" ;
    rdfs:comment "Links an enclosure to its dimensions record." ;
    rdfs:domain hcm:Enclosure ;
    rdfs:range hcm:EnclosureDimensions .

hcm:hasEnclosureIdentifier a owl:DatatypeProperty ;
    rdfs:label "has enclosure identifier" ;
    rdfs:comment "Records the identifier assigned to an enclosure or monitored enclosure." ;
    rdfs:domain hcm:Enclosure ;
    rdfs:range xsd:string .

hcm:hasEnrichment a owl:ObjectProperty ;
    rdfs:label "has enrichment" ;
    rdfs:comment "Relates an enclosure or monitored enclosure to an enrichment present or specified for it." ;
    rdfs:domain hcm:Enclosure ;
    rdfs:range hcm:Enrichment .

hcm:hasEnrichmentType a owl:DatatypeProperty ;
    rdfs:label "has enrichment type" ;
    rdfs:comment "Records the type or category of enrichment associated with an enrichment resource." ;
    rdfs:domain hcm:Enrichment ;
    rdfs:range xsd:string .

hcm:hasFacilityType a owl:DatatypeProperty ;
    rdfs:label "has facility type" ;
    rdfs:comment "Records the type of facility or housing area associated with an enclosure." ;
    rdfs:domain hcm:Enclosure ;
    rdfs:range xsd:string .

hcm:hasFloorArea a owl:DatatypeProperty ;
    rdfs:label "has floor area" ;
    rdfs:comment "Records the floor area value for an enclosure dimensions record." ;
    rdfs:domain hcm:EnclosureDimensions ;
    rdfs:range xsd:decimal .

hcm:hasFoodRequirement a owl:DatatypeProperty ;
    rdfs:label "has food requirement" ;
    rdfs:comment "Records a textual or coded food-provision requirement for an enclosure." ;
    rdfs:domain hcm:Enclosure ;
    rdfs:range xsd:string .

hcm:hasHeight a owl:DatatypeProperty ;
    rdfs:label "has height" ;
    rdfs:comment "Records the height value of an enclosure dimensions record." ;
    rdfs:domain hcm:EnclosureDimensions ;
    rdfs:range xsd:decimal .

hcm:hasLength a owl:DatatypeProperty ;
    rdfs:label "has length" ;
    rdfs:comment "Records the length value of an enclosure dimensions record." ;
    rdfs:domain hcm:EnclosureDimensions ;
    rdfs:range xsd:decimal .

hcm:hasManufacturer a owl:DatatypeProperty ;
    rdfs:label "has manufacturer" ;
    rdfs:comment "Records the manufacturer name for an enclosure." ;
    rdfs:domain hcm:Enclosure ;
    rdfs:range xsd:string .

hcm:hasSafetyRequirement a owl:DatatypeProperty ;
    rdfs:label "has safety requirement" ;
    rdfs:comment "Records a textual or coded safety requirement for an enclosure." ;
    rdfs:domain hcm:Enclosure ;
    rdfs:range xsd:string .

hcm:hasWaterRequirement a owl:DatatypeProperty ;
    rdfs:label "has water requirement" ;
    rdfs:comment "Records a textual or coded water-provision requirement for an enclosure." ;
    rdfs:domain hcm:Enclosure ;
    rdfs:range xsd:string .

hcm:hasWidth a owl:DatatypeProperty ;
    rdfs:label "has width" ;
    rdfs:comment "Records the width value of an enclosure dimensions record." ;
    rdfs:domain hcm:EnclosureDimensions ;
    rdfs:range xsd:decimal .

hcm:locatedIn a owl:ObjectProperty ;
    rdfs:label "located in" ;
    rdfs:comment "Relates an enclosure or monitored enclosure to the facility, room, rack, or other place in which it is situated." ;
    rdfs:domain hcm:Enclosure ;
    rdfs:range schema:Place .

hcm:hasUnit a owl:DatatypeProperty ;
    rdfs:label "has unit" ;
    rdfs:comment "Records the measurement unit associated with a quantitative observation result or measurement specification." ;
    rdfs:domain [ a owl:Class ;
        owl:unionOf ( hcm-obs:QuantityValue hcm-env:MeasurementSpecification ) ] ;
    rdfs:range xsd:string .

hcm:MonitoredEnclosure a owl:Class ;
    rdfs:label "Monitored Enclosure" ;
    rdfs:comment "A physical enclosure equipped for the longitudinal monitoring of housed biological subjects." ;
    rdfs:subClassOf hcm:Enclosure,
        [ a owl:Restriction ;
            owl:onProperty hcm:hasDimensions ;
            owl:allValuesFrom hcm:EnclosureDimensions ],
        [ a owl:Restriction ;
            owl:onProperty hcm:hasMonitoredAnimals ;
            owl:allValuesFrom hcm-bio:Subject ],
        [ a owl:Restriction ;
            owl:onProperty hcm-env:hasEnvironment ;
            owl:allValuesFrom hcm-env:EnvironmentProfile ],
        [ a owl:Restriction ;
            owl:onProperty hcm-tech:monitoredBy ;
            owl:allValuesFrom hcm-tech:Sensor ] .
